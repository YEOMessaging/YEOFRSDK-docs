{"abstract":[{"type":"text","text":"Get up and running with "},{"inlineContent":[{"type":"text","text":"YEOFR"}],"type":"strong"},{"text":" in minutes.","type":"text"}],"kind":"article","primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"1. Add the SDK","anchor":"1-Add-the-SDK"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Integrate ","type":"text"},{"type":"codeVoice","code":"YEOFR.xcframework"},{"text":" (or SPM package) into your project.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"import YEOFR","type":"codeVoice"},{"type":"text","text":" at the top of your Swift files."}]}]}]},{"type":"heading","level":2,"text":"2. Create a tracker","anchor":"2-Create-a-tracker"},{"type":"codeListing","syntax":"swift","code":["import YEOFR","","let sdk = YEOFRSDK.shared","_ = sdk.createTracker()"]},{"type":"heading","level":2,"text":"3. Detect faces from a pixel buffer","anchor":"3-Detect-faces-from-a-pixel-buffer"},{"type":"codeListing","syntax":"swift","code":["import AVFoundation","","\/\/ Inside your AVCaptureVideoDataOutput callback:","let dict = sdk.detectFaces(from: pixelBuffer, needFaceRect: true)","","print(dict[\"detectedCount\"] ?? 0)   \/\/ number of faces"]},{"type":"heading","level":2,"text":"4. Register a face","anchor":"4-Register-a-face"},{"type":"paragraph","inlineContent":[{"text":"Take a faceID returned from detection and give it a display name:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if let faceIDs = dict[\"faceIDs\"] as? [[String: Any]],","   let first = faceIDs.first,","   let index = first[\"index\"] as? Int {","","    let rc = sdk.enroll(faceID: Int64(index), name: \"Alice\", learnFromCurrentFrame: true)","    print(\"Enroll result:\", rc)","}"]},{"type":"codeListing","syntax":null,"code":["•\tfaceID comes from detection results.","•\tname is any string you want to associate with that face.","•\tSet learnFromCurrentFrame to true to train from the current image."]},{"type":"heading","level":2,"text":"5. Serialize tracker data","anchor":"5-Serialize-tracker-data"},{"type":"codeListing","syntax":"swift","code":["if let nsdata = sdk.faceRecognitionTrackerData() {","    let base64 = nsdata.base64EncodedString()","    \/\/ Save to disk or send to server","}"]},{"type":"heading","level":2,"text":"6. Load tracker data","anchor":"6-Load-tracker-data"},{"type":"codeListing","syntax":"swift","code":["if let blob = ... as NSData {","    _ = sdk.loadTracker(from: blob)","}"]},{"type":"heading","level":2,"text":"NOTES","anchor":"NOTES"},{"type":"codeListing","syntax":null,"code":["•\tYEOFRSDK is a singleton (shared) — activation runs once per process.","•\tPublic API is Foundation-based (NSData, NSDictionary, NSString) to ensure compatibility with Objective-C and React Native.","•\tFor Swift convenience, internal helpers wrap these as Data and value types."]}],"kind":"content"}],"sections":[],"metadata":{"modules":[{"name":"YEOFR"}],"role":"article","roleHeading":"Article","title":"QuickStart"},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/QuickStart","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/quickstart"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/yeofr\/quickstart"]}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"type":"topic","role":"collection","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","abstract":[{"type":"text","text":"A device-only face recognition SDK for iOS."}],"url":"\/documentation\/yeofr","title":"YEOFR","kind":"symbol"}},"variantOverrides":[{"traits":[{"interfaceLanguage":"occ"}],"patch":[{"value":"occ","path":"\/identifier\/interfaceLanguage","op":"replace"},{"value":null