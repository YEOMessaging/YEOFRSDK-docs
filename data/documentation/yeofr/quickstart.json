{"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/QuickStart","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"article","sections":[],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"1. Add the SDK","anchor":"1-Add-the-SDK"},{"items":[{"content":[{"inlineContent":[{"text":"Integrate ","type":"text"},{"code":"YEOFR.xcframework","type":"codeVoice"},{"text":" (or SPM package) into your project.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"import YEOFR","type":"codeVoice"},{"text":" at the top of your Swift files.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"1a. Pilot unlock for non-YEO bundle IDs","anchor":"1a-Pilot-unlock-for-non-YEO-bundle-IDs"},{"inlineContent":[{"text":"Starting with ","type":"text"},{"inlineContent":[{"text":"0.5.2","type":"text"}],"type":"strong"},{"text":", YEOFR is gated to YEO-owned apps by default —","type":"text"},{"text":" ","type":"text"},{"text":"non-YEO bundle IDs abort on the first ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/shared","type":"reference"},{"text":" access with","type":"text"},{"text":" ","type":"text"},{"text":"a printed contact hint.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For evaluation customers, we issue a ","type":"text"},{"inlineContent":[{"text":"temporary unlock code","type":"text"}],"type":"strong"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"bypasses the bundle gate during a fixed pilot window. Email","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"christo@yeomessaging.com"}]},{"text":" to request one.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Apply the code via a static call "},{"type":"strong","inlineContent":[{"text":"before","type":"text"}]},{"type":"text","text":" any "},{"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/shared","isActive":true},{"type":"text","text":" "},{"type":"text","text":"access — typically in your "},{"code":"@main App.init()","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import YEOFR","","@main","struct YourApp: App {","    init() {","        YEOFRSDK.activate(unlockCode: \"<contact-us-for-pilot-code>\")","    }","    var body: some Scene { WindowGroup { ContentView() } }","}"]},{"inlineContent":[{"text":"The code has a ","type":"text"},{"inlineContent":[{"type":"text","text":"hard expiry baked into the SDK build"}],"type":"strong"},{"text":". Once expired,","type":"text"},{"text":" ","type":"text"},{"text":"no code unlocks the gate regardless of value — request a fresh build.","type":"text"},{"text":" ","type":"text"},{"text":"This is a stop-gap for the 0.5.x cycle; the forward-looking licensing","type":"text"},{"text":" ","type":"text"},{"text":"scheme is tracked under CSI-384.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If your app is YEO-owned, this call is unnecessary (the gate passes","type":"text"},{"text":" ","type":"text"},{"text":"natively) but harmless.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"2. Create a tracker","anchor":"2-Create-a-tracker"},{"type":"codeListing","syntax":"swift","code":["import YEOFR","","let sdk = YEOFRSDK.shared","_ = sdk.createTracker()"]},{"level":2,"type":"heading","text":"2a. Check the framework compatability code","anchor":"2a-Check-the-framework-compatability-code"},{"inlineContent":[{"text":"Persist the compatability code alongside enrollment data. If it changes after a framework","type":"text"},{"text":" ","type":"text"},{"text":"update, require the user to re-enroll before loading stored tracker data.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let compatabilityCode = YEOFRSDK.compatabilityCode","print(compatabilityCode) \/\/ \"A\" or \"B\""]},{"inlineContent":[{"text":"Objective-C callers can use the framework metadata shim:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"objc","code":["NSString *compatabilityCode = [YEOFRFrameworkMetadata compatabilityCode];"]},{"level":2,"type":"heading","text":"3. Detect faces from a pixel buffer","anchor":"3-Detect-faces-from-a-pixel-buffer"},{"type":"codeListing","syntax":"swift","code":["import AVFoundation","","\/\/ Inside your AVCaptureVideoDataOutput callback:","let dict = sdk.detectFaces(from: pixelBuffer, needFaceRect: true)","","print(dict[\"detectedCount\"] ?? 0)   \/\/ number of faces"]},{"level":2,"type":"heading","text":"4. Register a face","anchor":"4-Register-a-face"},{"inlineContent":[{"text":"Take a faceID returned from detection and give it a display name:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["if let faceIDs = dict[\"faceIDs\"] as? [[String: Any]],","   let first = faceIDs.first,","   let index = first[\"index\"] as? Int {","","    let rc = sdk.enroll(faceID: Int64(index), name: \"Alice\", learnFromCurrentFrame: true)","    print(\"Enroll result:\", rc)","}"]},{"type":"codeListing","syntax":null,"code":["•\tfaceID comes from detection results.","•\tname is any string you want to associate with that face.","•\tSet learnFromCurrentFrame to true to train from the current image."]},{"level":2,"type":"heading","text":"5. Serialize tracker data","anchor":"5-Serialize-tracker-data"},{"type":"codeListing","syntax":"swift","code":["if let nsdata = sdk.faceRecognitionTrackerData() {","    let base64 = nsdata.base64EncodedString()","    \/\/ Save to disk or send to server","}"]},{"level":2,"type":"heading","text":"6. Load tracker data","anchor":"6-Load-tracker-data"},{"type":"codeListing","syntax":"swift","code":["if let blob = ... as NSData {","    _ = sdk.loadTracker(from: blob)","}"]},{"level":2,"type":"heading","text":"NOTES","anchor":"NOTES"},{"type":"codeListing","syntax":null,"code":["•\tYEOFRSDK is a singleton (shared) — activation runs once per process.","•\t`YEOFRSDK.compatabilityCode` is the supported source of truth for enrollment compatibility checks.","•\tPublic API is Foundation-based (NSData, NSDictionary, NSString) to ensure compatibility with Objective-C and React Native.","•\tFor Swift convenience, internal helpers wrap these as Data and value types."]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/quickstart"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/yeofr\/quickstart"]}],"abstract":[{"type":"text","text":"Get up and running with "},{"inlineContent":[{"type":"text","text":"YEOFR"}],"type":"strong"},{"type":"text","text":" in minutes."}],"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"metadata":{"title":"QuickStart","modules":[{"name":"YEOFR"}],"role":"article","roleHeading":"Article"},"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK/shared":{"title":"shared","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/shared","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"shared"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"YEOFRSDK","preciseIdentifier":"s:5YEOFR8YEOFRSDKC"}],"url":"\/documentation\/yeofr\/yeofrsdk\/shared","abstract":[{"text":"Global singleton instance.","type":"text"}],"role":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"kind":"symbol","url":"\/documentation\/yeofr","title":"YEOFR","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","abstract":[{"type":"text","text":"A device-only face recognition SDK for 