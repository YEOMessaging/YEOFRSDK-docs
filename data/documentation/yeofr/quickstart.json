{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/QuickStart","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"metadata":{"title":"QuickStart","roleHeading":"Article","role":"article","modules":[{"name":"YEOFR"}]},"abstract":[{"type":"text","text":"Recognise the enrolled user and reject everyone else, in a few lines."}],"seeAlsoSections":[{"anchor":"Getting-started","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService"],"generated":true,"title":"Getting started"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"1. Add the SDK","anchor":"1-Add-the-SDK"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the "},{"type":"strong","inlineContent":[{"type":"text","text":"YEOFR"}]},{"type":"text","text":" Swift package"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"https:\/\/github.com\/YEOMessaging\/YEOFR-SPM"},{"type":"text","text":") to your project, pinned to"},{"type":"text","text":" "},{"type":"text","text":"exact version "},{"type":"strong","inlineContent":[{"type":"text","text":"0.5.7"}]},{"type":"text","text":", then "},{"type":"codeVoice","code":"import YEOFR"},{"type":"text","text":". The binary is "},{"type":"strong","inlineContent":[{"type":"text","text":"arm64"},{"type":"text","text":" "},{"type":"text","text":"device-only"}]},{"type":"text","text":" — it does not run on the simulator."}]},{"level":2,"type":"heading","text":"2. Pilot unlock for non-YEO bundle IDs","anchor":"2-Pilot-unlock-for-non-YEO-bundle-IDs"},{"type":"paragraph","inlineContent":[{"type":"text","text":"YEOFR is gated to YEO-owned apps by default; a non-YEO bundle id aborts on"},{"type":"text","text":" "},{"type":"text","text":"construction. Evaluation customers get a "},{"type":"strong","inlineContent":[{"type":"text","text":"temporary unlock code"}]},{"type":"text","text":" that"},{"type":"text","text":" "},{"type":"text","text":"bypasses the gate during a fixed pilot window — email"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"christo@yeomessaging.com"}]},{"type":"text","text":" to request one. Pass it to the initializer"},{"type":"text","text":" "},{"type":"text","text":"(step 3). If your app’s bundle id is "},{"type":"codeVoice","code":"com.youreyeonly.*"},{"type":"text","text":", the gate passes"},{"type":"text","text":" "},{"type":"text","text":"natively."}]},{"level":2,"type":"heading","text":"3. Drive everything with `FaceTrustService`","anchor":"3-Drive-everything-with-FaceTrustService"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService"},{"type":"text","text":" is the turnkey entry point. It owns the engine, the"},{"type":"text","text":" "},{"type":"text","text":"camera, the fused-trust pipeline (face recognition + liveness CNN +"},{"type":"text","text":" "},{"type":"text","text":"TrueDepth), the identity gate, and tracker persistence, and exposes two"},{"type":"text","text":" "},{"type":"text","text":"streams: one for live trust verdicts and one for guided enrolment."}]},{"code":["import YEOFR","","let service = FaceTrustService(pilotUnlockCode: \"YOUR-PILOT-CODE\")","","\/\/ Attach the preview to an AVCaptureVideoPreviewLayer:","\/\/   previewLayer.session = service.previewSession","","try await service.start()    \/\/ warm-up, restore enrolment, arm gate, start camera"],"type":"codeListing","syntax":"swift"},{"text":"4. Enrol a face","anchor":"4-Enrol-a-face","type":"heading","level":2},{"inlineContent":[{"code":"enroll(name:)","type":"codeVoice"},{"text":" runs a short guided capture, persists the gallery, and","type":"text"},{"text":" ","type":"text"},{"text":"re-arms the identity gate. Iterate the returned stream to coach the user:","type":"text"}],"type":"paragraph"},{"code":["for await step in service.enroll(name: \"Alice\") {","    switch step.phase {","    case .capturing: show(step.prompt, progress: step.poseProgress)","    case .completed: dismiss()","    case .failed:    show(step.prompt)","    @unknown default: break","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"A single front pose is enough to separate the enrolled user from other","type":"text"},{"text":" ","type":"text"},{"text":"people. Pass ","type":"text"},{"code":"poses: PoseTarget.lightingAwareGallerySequence","type":"codeVoice"},{"text":" to also","type":"text"},{"text":" ","type":"text"},{"text":"capture off-axis poses + a lighting pass, which improves recall as the","type":"text"},{"text":" ","type":"text"},{"text":"user turns their head.","type":"text"}],"type":"paragraph"},{"text":"5. Run live recognition","anchor":"5-Run-live-recognition","type":"heading","level":2},{"code":["for await update in service.updates() {","    switch update.status {","    case .trusted:    badge(\"TRUSTED — \\(update.matchedName ?? \"\")\", .green)","    case .notTrusted: badge(\"NOT TRUSTED\", .red)","    case .badFraming: badge(\"ADJUST FRAMING\", .orange)","    case .noFace:     badge(\"NO FACE\", .gray)","    @unknown default: break","    }","    \/\/ update.livenessGenuine \/ update.depthIsThreeD are the contributing signals.","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"update.status == .trusted"},{"type":"text","text":" already fuses face recognition, liveness, and"},{"type":"text","text":" "},{"type":"text","text":"TrueDepth, with framing applied — you never pick a similarity threshold,"},{"type":"text","text":" "},{"type":"text","text":"and you never touch the identity gate (forgetting it would collapse trust"},{"type":"text","text":" "},{"type":"text","text":"to liveness + depth, so any live face would pass). The enrolled gallery is"},{"type":"text","text":" "},{"type":"text","text":"saved across launches automatically; "},{"type":"codeVoice","code":"service.enrolledName"},{"type":"text","text":" reflects who is"},{"type":"text","text":" "},{"type":"text","text":"enrolled."}]},{"level":2,"type":"heading","text":"See also","anchor":"See-also"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A complete, runnable SwiftUI app lives in the package’s ","type":"text"},{"type":"codeVoice","code":"Examples\/FRPilot"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService"},{"text":" — full API.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustUpdate"},{"text":" \/ ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress"},{"text":" — the stream payloads.","type":"text"}]}]}]}]}],"kind":"article","sections":[],"variants":[{"paths":["\/documentation\/yeofr\/quickstart"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/yeofr\/quickstart"],"traits":[{"interfaceLanguage":"occ"}]}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/EnrollmentProgress":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress","navigatorTitle":[{"text":"EnrollmentProgress","kind":"identifier"}],"kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EnrollmentProgress","kind":"identifier"}],"type":"topic","title":"EnrollmentProgress","url":"\/documentation\/yeofr\/enrollmentprogress","abstract":[{"text":"Progress for an in-flight enrolment capture. Yielded by","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService\/enroll(name:poses:)"},{"text":" and the stream finishes once the","type":"text"},{"text":" ","type":"text"},{"text":"gallery is banked (or the capture can’t start).","type":"text"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"url":"\/documentation\/yeofr","type":"topic","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","title":"YEOFR","kind":"symbol","role":"collection"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceTrustUpdate":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustUpdate","navigatorTitle":[{"text":"FaceTrustUpdate","kind":"identifier"}],"kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FaceTrustUpdate","kind":"identifier"}],"type":"topic","title":"FaceTrustUpdate","url":"\/documentation\/yeofr\/facetrustupdate","abstract":[{"text":"One per-frame trust readout, with the framing gate already applied — so the","type":"text"},{"text":" ","type":"text"},{"text":"consumer renders a state, not a fusion of raw signals. Yielded by","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService\/updates()","isActive":true},{"text":".","type":"text"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceTrustService/updates()":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService\/updates()","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"updates"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:ScS","kind":"typeIdentifier","text":"AsyncStream"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:5YEOFR15FaceTrustUpdateV","kind":"typeIdentifier","text":"FaceTrustUpdate"},{"kind":"text","text":">"}],"type":"topic","title":"updates()","url":"\/documentation\/yeofr\/facetrustservice\/updates()","abstract":[{"text":"Per-frame trust verdicts for the recognition UI. Call once and iterate;","type":"text"},{"text":" ","type":"text"},{"text":"the stream finishes on ","type":"text"},{"type":"codeVoice","code":"stop()"},{"text":". Newest-wins (the underlying camera","type":"text"},{"text":" ","type":"text"},{"text":"stream drops stale frames), so a slow consumer can’t back up memory.","type":"text"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceTrustService":{"title":"FaceTrustService","kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService","role":"symbol","type":"topic","url":"\/documentation\/yeofr\/facetrustservice","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FaceTrustService","kind":"identifier"}],"abstract":[{"text":"Turnkey entry point for on-device face recognition with fused liveness","type":"text"},{"text":" ","type":"text"},{"text":"and TrueDepth anti-spoofing.","type":"text"}],"navigatorTitle":[{"text":"FaceTrustService","kind":"identifier"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceTrustService/enroll(name:poses:)":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService\/enroll(name:poses:)","kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"enroll","kind":"identifier"},{"text":"(","kind":"text"},{"text":"name","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"poses","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"PoseTarget","kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR10PoseTargetO"},{"text":"]) -> ","kind":"text"},{"text":"AsyncStream","kind":"typeIdentifier","preciseIdentifier":"s:ScS"},{"text":"<","kind":"text"},{"text":"EnrollmentProgress","kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR18EnrollmentProgressV"},{"text":">","kind":"text"}],"type":"topic","title":"enroll(name:poses:)","url":"\/documentation\/yeofr\/facetrustservice\/enroll(name:poses:)","abstract":[{"type":"text","text":"Enrol "},{"type":"codeVoice","code":"name"},{"type":"text","text":" from the live camera and return a stream of capture"},{"type":"text","text":" "},{"type":"text","text":"progress. The existing frame loop drives the gallery walk; on completion"},{"type":"text","text":" "},{"type":"text","text":"the service persists the gallery, refreshes "},{"type":"codeVoice","code":"enrolledName"},{"type":"text","text":", resets the"},{"type":"text","text":" "},{"type":"text","text":"trust pipeline against the fresh gallery, and re-arms the identity gate —"},{"type":"text","text":" "},{"type":"text","text":"the consumer does none of that."}]}},"variantOverrides":[{"patch":[{"path":"\/identifier\/interfaceLanguage","op":"replace","value":"occ"},{"path":"\/topicSections","op":"add","value":null},{"path":"\/seeAlsoSections","op":"replace","value":[{"anchor":"Getting-started","identifiers":[],"generated":true,"title":"Getting started"}]}],"traits":[{"interfaceLanguage":"occ"}]}]}