{"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/QuickStart","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"primaryContentSections":[{"kind":"content","content":[{"text":"1. Add the SDK","level":2,"anchor":"1-Add-the-SDK","type":"heading"},{"inlineContent":[{"text":"Add the ","type":"text"},{"inlineContent":[{"type":"text","text":"YEOFR"}],"type":"strong"},{"text":" Swift package","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"https:\/\/github.com\/YEOMessaging\/YEOFR-SPM","type":"codeVoice"},{"text":") to your project, pinned to","type":"text"},{"text":" ","type":"text"},{"text":"exact version ","type":"text"},{"inlineContent":[{"type":"text","text":"0.7.0"}],"type":"strong"},{"text":", then ","type":"text"},{"code":"import YEOFR","type":"codeVoice"},{"text":". The binary is ","type":"text"},{"inlineContent":[{"type":"text","text":"arm64"},{"type":"text","text":" "},{"type":"text","text":"device-only"}],"type":"strong"},{"text":" — it does not run on the simulator.","type":"text"}],"type":"paragraph"},{"anchor":"2-Pilot-unlock-for-non-YEO-bundle-IDs","level":2,"text":"2. Pilot unlock for non-YEO bundle IDs","type":"heading"},{"inlineContent":[{"text":"YEOFR is gated to YEO-owned apps by default; a non-YEO bundle id aborts on","type":"text"},{"text":" ","type":"text"},{"text":"construction. Evaluation customers get a ","type":"text"},{"inlineContent":[{"type":"text","text":"temporary unlock code"}],"type":"strong"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"bypasses the gate during a fixed pilot window — email","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"christo@yeomessaging.com"}],"type":"strong"},{"text":" to request one. Pass it to the initializer","type":"text"},{"text":" ","type":"text"},{"text":"(step 3). YEO-owned apps pass the gate natively.","type":"text"}],"type":"paragraph"},{"anchor":"3-Drive-everything-with-FaceTrustService","level":2,"text":"3. Drive everything with `FaceTrustService`","type":"heading"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService","type":"reference"},{"text":" is the turnkey entry point. It owns the engine, the","type":"text"},{"text":" ","type":"text"},{"text":"camera, the fused-trust pipeline (face recognition + liveness CNN +","type":"text"},{"text":" ","type":"text"},{"text":"TrueDepth), the identity gate, and tracker persistence, and exposes two","type":"text"},{"text":" ","type":"text"},{"text":"streams: one for live trust verdicts and one for guided enrolment.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["import YEOFR","","let service = FaceTrustService(pilotUnlockCode: \"YOUR-PILOT-CODE\")","","\/\/ Attach the preview to an AVCaptureVideoPreviewLayer:","\/\/   previewLayer.session = service.previewSession","","try await service.start()    \/\/ warm-up, restore enrolment, arm gate, start camera"],"type":"codeListing"},{"text":"4. Enrol a face","level":2,"anchor":"4-Enrol-a-face","type":"heading"},{"inlineContent":[{"code":"enroll(name:)","type":"codeVoice"},{"text":" runs a short guided capture, persists the gallery, and","type":"text"},{"text":" ","type":"text"},{"text":"re-arms the identity gate. Iterate the returned stream to coach the user:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["for await step in service.enroll(name: \"Alice\") {","    switch step.phase {","    case .capturing: show(step.prompt, progress: step.poseProgress)","    case .completed: dismiss()","    case .failed:    show(step.prompt)","    @unknown default: break","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"A single front pose is enough to separate the enrolled user from other","type":"text"},{"text":" ","type":"text"},{"text":"people. Pass ","type":"text"},{"code":"poses: PoseTarget.lightingAwareGallerySequence","type":"codeVoice"},{"text":" to also","type":"text"},{"text":" ","type":"text"},{"text":"capture off-axis poses + a lighting pass, which improves recall as the","type":"text"},{"text":" ","type":"text"},{"text":"user turns their head.","type":"text"}],"type":"paragraph"},{"anchor":"5-Run-live-recognition","level":2,"text":"5. Run live recognition","type":"heading"},{"syntax":"swift","code":["for await update in service.updates() {","    switch update.status {","    case .trusted:    badge(\"TRUSTED — \\(update.matchedName ?? \"\")\", .green)","    case .notTrusted: badge(\"NOT TRUSTED\", .red)","    case .badFraming: badge(\"ADJUST FRAMING\", .orange)","    case .noFace:     badge(\"NO FACE\", .gray)","    @unknown default: break","    }","    \/\/ update.livenessGenuine \/ update.depthIsThreeD are the contributing signals.","}"],"type":"codeListing"},{"inlineContent":[{"code":"update.status == .trusted","type":"codeVoice"},{"text":" already fuses face recognition, liveness, and","type":"text"},{"text":" ","type":"text"},{"text":"TrueDepth, with framing applied — you never pick a similarity threshold,","type":"text"},{"text":" ","type":"text"},{"text":"and you never touch the identity gate (forgetting it would collapse trust","type":"text"},{"text":" ","type":"text"},{"text":"to liveness + depth, so any live face would pass). The enrolled gallery is","type":"text"},{"text":" ","type":"text"},{"text":"saved across launches automatically; ","type":"text"},{"code":"service.enrolledName","type":"codeVoice"},{"text":" reflects who is","type":"text"},{"text":" ","type":"text"},{"text":"enrolled.","type":"text"}],"type":"paragraph"},{"anchor":"See-also","level":2,"text":"See also","type":"heading"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A complete, runnable SwiftUI app lives in the package’s "},{"code":"Examples\/FRPilot","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService"},{"type":"text","text":" — full API."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustUpdate"},{"type":"text","text":" \/ "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress"},{"type":"text","text":" — the stream payloads."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"kind":"article","metadata":{"title":"QuickStart","role":"article","modules":[{"name":"YEOFR"}],"roleHeading":"Article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/quickstart"]},{"paths":["\/documentation\/yeofr\/quickstart"],"traits":[{"interfaceLanguage":"occ"}]}],"seeAlsoSections":[{"generated":true,"anchor":"Getting-started","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService"],"title":"Getting started"}],"abstract":[{"text":"Recognise the enrolled user and reject everyone else, in a few lines.","type":"text"}],"sections":[],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceTrustService/updates()":{"url":"\/documentation\/yeofr\/facetrustservice\/updates()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"updates"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:ScS","kind":"typeIdentifier","text":"AsyncStream"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:5YEOFR15FaceTrustUpdateV","kind":"typeIdentifier","text":"FaceTrustUpdate"},{"kind":"text","text":">"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService\/updates()","role":"symbol","kind":"symbol","abstract":[{"text":"Per-frame trust verdicts for the recognition UI. Call once and iterate;","type":"text"},{"type":"text","text":" "},{"text":"the stream finishes on ","type":"text"},{"type":"codeVoice","code":"stop()"},{"type":"text","text":". Newest-wins (the underlying camera"},{"type":"text","text":" "},{"type":"text","text":"stream drops stale frames), so a slow consumer can’t back up memory."}],"type":"topic","title":"updates()"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"abstract":[{"text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing.","type":"text"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","type":"topic","title":"YEOFR","role":"collection","url":"\/documentation\/yeofr","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceTrustService":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FaceTrustService","kind":"identifier"}],"url":"\/documentation\/yeofr\/facetrustservice","kind":"symbol","navigatorTitle":[{"text":"FaceTrustService","kind":"identifier"}],"abstract":[{"type":"text","text":"Turnkey entry point for on-device face recognition with fused liveness"},{"type":"text","text":" "},{"type":"text","text":"and TrueDepth anti-spoofing."}],"title":"FaceTrustService","role":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService","type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceTrustService/enroll(name:poses:)":{"abstract":[{"type":"text","text":"Enrol "},{"code":"name","type":"codeVoice"},{"type":"text","text":" from the live camera and return a stream of capture"},{"type":"text","text":" "},{"type":"text","text":"progress. The existing frame loop drives the gallery walk; on completion"},{"type":"text","text":" "},{"type":"text","text":"the service persists the gallery, refreshes "},{"code":"enrolledName","type":"codeVoice"},{"type":"text","text":", resets the"},{"type":"text","text":" "},{"type":"text","text":"trust pi