{"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"kind":"article","abstract":[{"text":"Get up and running with ","type":"text"},{"inlineContent":[{"type":"text","text":"YEOFR"}],"type":"strong"},{"type":"text","text":" in minutes."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/quickstart"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/yeofr\/quickstart"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"YEOFR"}],"roleHeading":"Article","role":"article","title":"QuickStart"},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/QuickStart"},"primaryContentSections":[{"kind":"content","content":[{"text":"1. Add the SDK","type":"heading","level":2,"anchor":"1-Add-the-SDK"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Integrate ","type":"text"},{"code":"YEOFR.xcframework","type":"codeVoice"},{"type":"text","text":" (or SPM package) into your project."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"import YEOFR","type":"codeVoice"},{"type":"text","text":" at the top of your Swift files."}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"1a. Pilot unlock for non-YEO bundle IDs","anchor":"1a-Pilot-unlock-for-non-YEO-bundle-IDs"},{"inlineContent":[{"text":"Starting with ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"0.5.2"}]},{"text":", YEOFR is gated to YEO-owned apps by default —","type":"text"},{"text":" ","type":"text"},{"text":"any bundle ID ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" starting with "},{"code":"com.youreyeonly.","type":"codeVoice"},{"text":" aborts on the first","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/shared","isActive":true,"type":"reference"},{"text":" access with a printed contact hint.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For evaluation customers, we issue a ","type":"text"},{"inlineContent":[{"type":"text","text":"temporary unlock code"}],"type":"strong"},{"text":" that","type":"text"},{"text":" ","type":"text"},{"text":"bypasses the bundle-prefix check during a fixed pilot window. Email","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"christo@yeomessaging.com"}],"type":"strong"},{"text":" to request one.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Apply the code via a static call ","type":"text"},{"inlineContent":[{"type":"text","text":"before"}],"type":"strong"},{"text":" any ","type":"text"},{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/shared","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"access — typically in your ","type":"text"},{"code":"@main App.init()","type":"codeVoice"},{"text":":","type":"text"}]},{"code":["import YEOFR","","@main","struct YourApp: App {","    init() {","        YEOFRSDK.activate(unlockCode: \"<contact-us-for-pilot-code>\")","    }","    var body: some Scene { WindowGroup { ContentView() } }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The code has a ","type":"text"},{"inlineContent":[{"type":"text","text":"hard expiry baked into the SDK build"}],"type":"strong"},{"text":". Once expired,","type":"text"},{"text":" ","type":"text"},{"text":"no code unlocks the gate regardless of value — request a fresh build.","type":"text"},{"text":" ","type":"text"},{"text":"This is a stop-gap for the 0.5.x cycle; the forward-looking licensing","type":"text"},{"text":" ","type":"text"},{"text":"scheme is tracked under CSI-384.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If your bundle ID already starts with ","type":"text"},{"code":"com.youreyeonly.","type":"codeVoice"},{"text":", this call is","type":"text"},{"text":" ","type":"text"},{"text":"unnecessary (the prefix path already passes) but harmless.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"2. Create a tracker","anchor":"2-Create-a-tracker"},{"code":["import YEOFR","","let sdk = YEOFRSDK.shared","_ = sdk.createTracker()"],"type":"codeListing","syntax":"swift"},{"level":2,"type":"heading","text":"2a. Check the framework compatability code","anchor":"2a-Check-the-framework-compatability-code"},{"inlineContent":[{"type":"text","text":"Persist the compatability code alongside enrollment data. If it changes after a framework"},{"type":"text","text":" "},{"type":"text","text":"update, require the user to re-enroll before loading stored tracker data."}],"type":"paragraph"},{"code":["let compatabilityCode = YEOFRSDK.compatabilityCode","print(compatabilityCode) \/\/ \"A\" or \"B\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Objective-C callers can use the framework metadata shim:"}],"type":"paragraph"},{"code":["NSString *compatabilityCode = [YEOFRFrameworkMetadata compatabilityCode];"],"type":"codeListing","syntax":"objc"},{"level":2,"type":"heading","text":"3. Detect faces from a pixel buffer","anchor":"3-Detect-faces-from-a-pixel-buffer"},{"code":["import AVFoundation","","\/\/ Inside your AVCaptureVideoDataOutput callback:","let dict = sdk.detectFaces(from: pixelBuffer, needFaceRect: true)","","print(dict[\"detectedCount\"] ?? 0)   \/\/ number of faces"],"syntax":"swift","type":"codeListing"},{"level":2,"type":"heading","text":"4. Register a face","anchor":"4-Register-a-face"},{"inlineContent":[{"type":"text","text":"Take a faceID returned from detection and give it a display name:"}],"type":"paragraph"},{"code":["if let faceIDs = dict[\"faceIDs\"] as? [[String: Any]],","   let first = faceIDs.first,","   let index = first[\"index\"] as? Int {","","    let rc = sdk.enroll(faceID: Int64(index), name: \"Alice\", learnFromCurrentFrame: true)","    print(\"Enroll result:\", rc)","}"],"type":"codeListing","syntax":"swift"},{"code":["•\tfaceID comes from detection results.","•\tname is any string you want to associate with that face.","•\tSet learnFromCurrentFrame to true to train from the current image."],"syntax":null,"type":"codeListing"},{"text":"5. Serialize tracker data","anchor":"5-Serialize-tracker-data","level":2,"type":"heading"},{"code":["if let nsdata = sdk.faceRecognitionTrackerData() {","    let base64 = nsdata.base64EncodedString()","    \/\/ Save to disk or send to server","}"],"syntax":"swift","type":"codeListing"},{"text":"6. Load tracker data","anchor":"6-Load-tracker-data","level":2,"type":"heading"},{"code":["if let blob = ... as NSData {","    _ = sdk.loadTracker(from: blob)","}"],"syntax":"swift","type":"codeListing"},{"text":"NOTES","anchor":"NOTES","level":2,"type":"heading"},{"code":["•\tYEOFRSDK is a singleton (shared) — activation runs once per process.","•\t`YEOFRSDK.compatabilityCode` is the supported source of truth for enrollment compatibility checks.","•\tPublic API is Foundation-based (NSData, NSDictionary, NSString) to ensure compatibility with Objective-C and React Native.","•\tFor Swift convenience, internal helpers wrap these as Data and value types."],"syntax":null,"type":"codeListing"}]}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK/shared":{"url":"\/documentation\/yeofr\/yeofrsdk\/shared","abstract":[{"text":"Global singleton instance.","type":"text"}],"title":"shared","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"shared"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR8YEOFRSDKC","text":"YEOFRSDK"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/shared","kind":"symbol","type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"url":"\/documentation\/yeofr","role":"collection","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","abstract":[{"type":"text","text":"A device-only face recognition SDK for iOS."}],"type":"topic","title":"YEOFR","kind":"symbol"}},"variantOverrides":[{"patch":[{"path":"\/identifier\/interfaceLanguage","value":"occ","op":"replace"},{"path":"\/topicSections","value":null,"op":"add"},{"path":"\/seeAlsoSections","value":null,"op":"add"}],"traits":[{"interfaceLanguage":"occ"}]}]}