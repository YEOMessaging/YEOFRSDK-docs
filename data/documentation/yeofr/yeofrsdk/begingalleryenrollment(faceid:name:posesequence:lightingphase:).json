{"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginGalleryEnrollment(faceID:name:poseSequence:lightingPhase:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"beginGalleryEnrollment"},{"kind":"text","text":"("},{"kind":"externalParam","text":"faceID"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5Int64V","text":"Int64","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"poseSequence"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:5YEOFR10PoseTargetO","kind":"typeIdentifier","text":"PoseTarget","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget"},{"kind":"text","text":"] = PoseTarget.defaultGallerySequence, "},{"text":"lightingPhase","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:5YEOFR19LightingPhaseConfigV","text":"LightingPhaseConfig","kind":"typeIdentifier","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"},{"text":" = .standard) -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FRSDKReturnCode","preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","text":"FRSDKReturnCode"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The SDK gates capture on the user’s live head orientation: the"},{"type":"text","text":" "},{"type":"text","text":"current pose’s accumulator only fills while "},{"type":"codeVoice","code":"VNFaceObservation"},{"type":"text","text":"‘s"},{"type":"text","text":" "},{"type":"text","text":"yaw\/pitch matches the current "},{"type":"codeVoice","code":"PoseTarget"},{"type":"text","text":", and the session"},{"type":"text","text":" "},{"type":"text","text":"auto-advances when the user moves into the next pose’s target."},{"type":"text","text":" "},{"type":"codeVoice","code":"advanceToNextPose()"},{"type":"text","text":" remains available as a manual escape hatch"},{"type":"text","text":" "},{"type":"text","text":"for users who can’t physically tilt."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"lightingPhase"},{"type":"text","text":" selects the trailing lighting phase’s termination"},{"type":"text","text":" "},{"type":"text","text":"policy: "},{"type":"codeVoice","code":".standard"},{"type":"text","text":" (default — hunt for 3 distinct conditions, ~45 s"},{"type":"text","text":" "},{"type":"text","text":"backstop) or "},{"type":"codeVoice","code":".walkAround"},{"type":"text","text":" (“walk around for ~1 minute, capture every"},{"type":"text","text":" "},{"type":"text","text":"distinct condition found” — unbounded count, ~60 s budget). It only"},{"type":"text","text":" "},{"type":"text","text":"has an effect when "},{"code":"poseSequence","type":"codeVoice"},{"type":"text","text":" ends with a repeat "},{"type":"codeVoice","code":".front"},{"type":"text","text":" "},{"text":"(","type":"text"},{"type":"codeVoice","code":"PoseTarget.lightingAwareGallerySequence"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"text":"The engine drives the same host ring for every pose: it angle-gates each","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"angular pose on the live Vision yaw\/pitch and learns each pose’s"},{"type":"text","text":" "},{"type":"text","text":"appearances as "},{"type":"codeVoice","code":"detectFaces"},{"type":"text","text":" keeps the named face in view. Poll"},{"type":"text","text":" "},{"type":"codeVoice","code":"galleryEnrollmentStatus"},{"type":"text","text":" for per-pose prompts; the save signal is"},{"type":"text","text":" "},{"code":"faceRecognitionTrackerData()","type":"codeVoice"},{"type":"text","text":" becoming non-empty once the walk completes."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","metadata":{"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"beginGalleryEnrollment"},{"kind":"text","text":"("},{"kind":"externalParam","text":"faceID"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5Int64V","kind":"typeIdentifier","text":"Int64"},{"kind":"text","text":", "},{"text":"name","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"poseSequence"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:5YEOFR10PoseTargetO","kind":"typeIdentifier","text":"PoseTarget"},{"text":"], ","kind":"text"},{"text":"lightingPhase","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:5YEOFR19LightingPhaseConfigV","kind":"typeIdentifier","text":"LightingPhaseConfig"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","text":"FRSDKReturnCode","kind":"typeIdentifier"}],"externalID":"s:5YEOFR8YEOFRSDKC22beginGalleryEnrollment6faceID4name12poseSequence13lightingPhaseAA15FRSDKReturnCodeOs5Int64V_SSSayAA10PoseTargetOGAA08LightingL6ConfigVtF","role":"symbol","modules":[{"name":"YEOFR"}],"title":"beginGalleryEnrollment(faceID:name:poseSequence:lightingPhase:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation