ginGalleryEnrollment"},{"kind":"text","text":"("},{"kind":"externalParam","text":"faceID"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5Int64V","kind":"typeIdentifier","text":"Int64"},{"kind":"text","text":", "},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"poseSequence"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:5YEOFR10PoseTargetO","kind":"typeIdentifier","text":"PoseTarget","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget"},{"kind":"text","text":"] = PoseTarget.defaultGallerySequence, "},{"kind":"externalParam","text":"lightingPhase"},{"kind":"text","text":": "},{"preciseIdentifier":"s:5YEOFR19LightingPhaseConfigV","kind":"typeIdentifier","text":"LightingPhaseConfig","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"},{"kind":"text","text":" = .standard) -> "},{"preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","kind":"typeIdentifier","text":"FRSDKReturnCode","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FRSDKReturnCode"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The SDK gates capture on the user’s live head orientation: the"},{"type":"text","text":" "},{"type":"text","text":"current pose’s accumulator only fills while "},{"type":"codeVoice","code":"VNFaceObservation"},{"type":"text","text":"‘s"},{"type":"text","text":" "},{"type":"text","text":"yaw\/pitch matches the current "},{"type":"codeVoice","code":"PoseTarget"},{"type":"text","text":", and the session"},{"type":"text","text":" "},{"type":"text","text":"auto-advances when the user moves into the next pose’s target."},{"type":"text","text":" "},{"code":"advanceToNextPose()","type":"codeVoice"},{"type":"text","text":" remains available as a manual escape hatch"},{"type":"text","text":" "},{"type":"text","text":"for users who can’t physically tilt."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"lightingPhase"},{"type":"text","text":" selects the trailing lighting phase’s termination"},{"type":"text","text":" "},{"type":"text","text":"policy: "},{"type":"codeVoice","code":".standard"},{"type":"text","text":" (default — hunt for 3 distinct conditions, ~45 s"},{"type":"text","text":" "},{"type":"text","text":"backstop) or "},{"type":"codeVoice","code":".walkAround"},{"type":"text","text":" (“walk around for ~1 minute, capture every"},{"type":"text","text":" "},{"type":"text","text":"distinct condition found” — unbounded count, ~60 s budget). It only"},{"type":"text","text":" "},{"type":"text","text":"has an effect when "},{"type":"codeVoice","code":"poseSequence"},{"type":"text","text":" ends with a repeat "},{"type":"codeVoice","code":".front"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"PoseTarget.lightingAwareGallerySequence"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The engine drives the same host ring for every pose: it angle-gates each"},{"type":"text","text":" "},{"type":"text","text":"angular pose on the live Vision yaw\/pitch and learns each pose’s"},{"type":"text","text":" "},{"type":"text","text":"appearances as "},{"type":"codeVoice","code":"detectFaces"},{"type":"text","text":" keeps the named face in view. Poll"},{"type":"text","text":" "},{"type":"codeVoice","code":"galleryEnrollmentStatus"},{"type":"text","text":" for per-pose prompts; the save signal is"},{"type":"text","text":" "},{"type":"codeVoice","code":"faceRecognitionTrackerData()"},{"type":"text","text":" becoming non-empty once the walk completes."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Begin a multi-pose (“gallery”) enrollment with caller-supplied","type":"text"},{"text":" ","type":"text"},{"text":"pose targets. Each pose is captured and vetted independently","type":"text"},{"text":" ","type":"text"},{"text":"through ","type":"text"},{"code":"EnrollmentVetting","type":"codeVoice"},{"text":"; the per-centroid radius-floor of","type":"text"},{"text":" ","type":"text"},{"text":"0.95 still holds for every captured centroid, preserving the","type":"text"},{"text":" ","type":"text"},{"text":"non-enrolled-colleague dead-zone.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/yeofrsdk\/begingalleryenrollment(faceid:name:posesequence:lightingphase:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK":{"type":"topic","url":"\/documentation\/yeofr\/yeofrsdk","navigatorTitle":[{"kind":"identifier","text":"YEOFRSDK"}],"role":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK","title":"YEOFRSDK","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"YEOFRSDK","kind":"identifier"}],"abstract":[{"text":"YEOFR main entry point.","type":"text"}],"kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK/beginGalleryEnrollment(faceID:name:poseSequence:lightingPhase:)":{"url":"\/documentation\/yeofr\/yeofrsdk\/begingalleryenrollment(faceid:name:posesequence:lightingphase:)","type":"topic","role":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginGalleryEnrollment(faceID:name:poseSequence:lightingPhase:)","title":"beginGalleryEnrollment(faceID:name:poseSequence:lightingPhase:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginGalleryEnrollment","kind":"identifier"},{"text":"(","kind":"text"},{"text":"faceID","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int64","kind":"typeIdentifier","preciseIdentifier":"s:s5Int64V"},{"text":", ","kind":"tex