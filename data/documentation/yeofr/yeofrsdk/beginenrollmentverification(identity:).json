s strand users).","type":"text"},{"text":" ","type":"text"},{"text":"Returns ","type":"text"},{"code":".trackerIsNull","type":"codeVoice"},{"text":" when the identity isn’t enrolled or","type":"text"},{"text":" ","type":"text"},{"text":"another session owns the embedding feed (also the constant return","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for engines without the verification walk, e.g. Luxand)."}]}],"kind":"content"}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/yeofrsdk\/beginenrollmentverification(identity:)"]}],"metadata":{"externalID":"s:5YEOFR8YEOFRSDKC27beginEnrollmentVerification8identityAA15FRSDKReturnCodeOSS_tF","role":"symbol","modules":[{"name":"YEOFR"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginEnrollmentVerification","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identity","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"FRSDKReturnCode","preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","kind":"typeIdentifier"}],"title":"beginEnrollmentVerification(identity:)","symbolKind":"method","roleHeading":"Instance Method"},"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"role":"collection","url":"\/documentation\/yeofr","type":"topic","title":"YEOFR"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK/beginEnrollmentVerification(identity:)":{"abstract":[{"type":"text","text":"Phase 2 of the two-phase enrolment contract: arm the verification"},{"type":"text","text":" "},{"type":"text","text":"walk for a just-enrolled (in-memory, not ye