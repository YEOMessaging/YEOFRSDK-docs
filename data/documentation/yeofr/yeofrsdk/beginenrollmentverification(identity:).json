{"metadata":{"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginEnrollmentVerification","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identity","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","text":"FRSDKReturnCode","kind":"typeIdentifier"}],"modules":[{"name":"YEOFR"}],"role":"symbol","title":"beginEnrollmentVerification(identity:)","symbolKind":"method","externalID":"s:5YEOFR8YEOFRSDKC27beginEnrollmentVerification8identityAA15FRSDKReturnCodeOSS_tF"},"sections":[],"abstract":[{"text":"Phase 2 of the two-phase enrolment contract: arm the verification","type":"text"},{"text":" ","type":"text"},{"text":"walk for a just-enrolled (in-memory, not yet persisted) identity.","type":"text"},{"text":" ","type":"text"},{"text":"Subsequent single-face, valid-framing recognition frames are","type":"text"},{"text":" ","type":"text"},{"text":"scored against its gallery; ","type":"text"},{"code":"enrollmentVerificationStatus","type":"codeVoice"},{"type":"text","text":" reports"},{"text":" ","type":"text"},{"type":"text","text":"live progress and, at "},{"code":"finishEnrollmentVerification()","type":"codeVoice"},{"type":"text","text":" (or the"},{"type":"text","text":" "},{"type":"text","text":"~60 s budget), the walk’s FRR evidence —"},{"type":"text","text":" "},{"type":"codeVoice","code":"recognizedFrames \/ framesVerified"},{"type":"text","text":" is the enrolment’s measured"},{"type":"text","text":" "},{"type":"text","text":"live recognition rate, "},{"type":"codeVoice","code":"centroidHitCounts"},{"type":"text","text":" shows which centroids"},{"type":"text","text":" "},{"type":"text","text":"carried it."}],"hierarchy":{"paths":[["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/YEOFRSDK"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginEnrollmentVerification","kind":"identifier"},{"kind":"text","text":"("},{"text":"identity","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":") -> "},{"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FRSDKReturnCode","kind":"typeIdentifier","text":"FRSDKReturnCode","preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO"}],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"The walk also PATCHES the gaps it measures: an FRR moment (the"},{"type":"text","text":" "},{"text":"gallery fails the live user) feeds the rejected-positive capture","type":"text"},{"text":" ","type":"text"},{"text":"pipeline — accumulate, vet (consistency 0.90), guard (anchor 0.70","type":"text"},{"text":" ","type":"text"},{"text":"walk-1 parity, cross-identity, novelty) — and the staged centroids","type":"text"},{"text":" ","type":"text"},{"text":"are appended to the in-memory gallery at finish, so the host’s","type":"text"},{"text":" ","type":"text"},{"text":"post-walk persist saves the patched gallery (","type":"text"},{"code":"centroidsAdded","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"galleryCount"},{"text":" on the outcome; ","type":"text"},{"code":"rescuedFrames","type":"codeVoice"},{"text":" counts the frames a","type":"text"},{"text":" ","type":"text"},{"text":"patch covered live). The measured FRR is always scored against the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"original gallery — patches never inflate it. Cancel discards the"},{"type":"text","text":" "},{"type":"text","text":"patches."}],"type":"paragraph"},{"inlineContent":[{"text":"Hosts should run this between gallery completion and persisting","type":"text"},{"type":"text","text":" "},{"text":"the tracker, surface the rate to the user, and persist regardless","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the result (recommend a re-enrol on a low unpatched rate rather"},{"type":"text","text":" "},{"type":"text","text":"than failing the save — reject loops strand users)."},{"type":"text","text":" "},{"type":"text","text":"Returns "},{"type":"codeVoice","code":".trackerIsNull"},{"type":"text","text":" when the identity isn’t enrolled or"},{"type":"text","text":" "},{"type":"text","text":"another session owns the embedding feed (also the constant return"},{"type":"text","text":" "},{"type":"text","text":"for engines without the verification walk, e.g. Luxand)."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginEnrollmentVerification(identity:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/yeofrsdk\/beginenrollmentverification(identity:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","references":{"doc://com.yeomessaging.YEOFR/documentation/YEOFR/YEOFRSDK":{"url":"\/documentation\/yeofr\/yeofrsdk","navigatorTitle":[{"kind":"identifier","text":"YEOFRSDK"}],"kind":"symbol","abstract":[{"text":"YEOFR main entry point.","type":"text"}],"title":"YEOFRSDK","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/YEOFRSDK","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"YEOFRSDK"}],"role":"symbol"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/FRSDKReturnCode":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"FRSDKReturn