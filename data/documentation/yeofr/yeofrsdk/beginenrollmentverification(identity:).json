{"metadata":{"role":"symbol","externalID":"s:5YEOFR8YEOFRSDKC27beginEnrollmentVerification8identityAA15FRSDKReturnCodeOSS_tF","modules":[{"name":"YEOFR"}],"title":"beginEnrollmentVerification(identity:)","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"beginEnrollmentVerification"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"FRSDKReturnCode","preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO"}],"symbolKind":"method"},"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginEnrollmentVerification(identity:)","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK"]]},"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"beginEnrollmentVerification"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"FRSDKReturnCode","preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FRSDKReturnCode"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The walk also PATCHES the gaps it measures: an FRR moment (the"},{"type":"text","text":" "},{"type":"text","text":"gallery fails the live user) feeds the rejected-positive capture"},{"type":"text","text":" "},{"type":"text","text":"pipeline — accumulate, vet (consistency 0.90), guard (anchor 0.70"},{"type":"text","text":" "},{"type":"text","text":"walk-1 parity, cross-identity, novelty) — and the staged centroids"},{"type":"text","text":" "},{"type":"text","text":"are appended to the in-memory gallery at finish, so the host’s"},{"type":"text","text":" "},{"type":"text","text":"post-walk persist saves the patched gallery ("},{"type":"codeVoice","code":"centroidsAdded"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"type":"codeVoice","code":"galleryCount"},{"type":"text","text":" on the outcome; "},{"type":"codeVoice","code":"rescuedFrames"},{"type":"text","text":" counts the frames a"},{"type":"text","text":" "},{"type":"text","text":"patch covered live). The measured FRR is always scored against the"},{"type":"text","text":" "},{"type":"text","text":"original gallery — patches never inflate it. Cancel discards the"},{"type":"text","text":" "},{"type":"text","text":"patches."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Hosts should run this between gallery completion and persisting"},{"type":"text","text":" "},{"type":"text","text":"the tracker, surface the rate to the user, and persist regardless"},{"type":"text","text":" "},{"type":"text","text":"of the result (recommend a re-enrol on a low unpatched rate rather"},{"type":"text","text":" "},{"type":"text","text":"than failing the save — reject loops strand users)."},{"type":"text","text":" "},{"type":"text","text":"Returns "},{"type":"codeVoice","code":".trackerIsNull"},{"type":"text","text":" when the identity isn’t enrolled or"},{"type":"text","text":" "},{"type":"text","text":"another session owns the embedding feed (also the constant return"},{"type":"text","text":" "},{"type":"text","text":"for engines without the verification walk, e.g. Luxand)."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Phase 2 of the two-phase enrolment contract: arm the verification","type":"text"},{"text":" ","type":"text"},{"text":"walk for a just-enrolled (in-memory, not yet persisted) identity.","type":"text"},{"text":" ","type":"text"},{"text":"Subsequent single-face, valid-framing recognition frames are","type":"text"},{"text":" ","type":"text"},{"text":"scored against its gallery; ","type":"text"},{"code":"enrollmentVerificationStatus","type":"codeVoice"},{"text":" reports","type":"text"},{"text":" ","type":"text"},{"text":"live progress and, at ","type":"text"},{"code":"finishEnrollmentVerification()","type":"codeVoice"},{"text":" (or the","type":"text"},{"text":" ","type":"text"},{"text":"~60 s budget), the walk’s FRR evidence —","type":"text"},{"text":" ","type":"text"},{"code":"recognizedFrames \/ framesVerified","type":"codeVoice"},{"text":" is the enrolment’s measured","type":"text"},{"text":" ","type":"text"},{"text":"live recognition rate, ","type":"text"},{"code":"centroidHitCounts","type":"codeVoice"},{"text":" shows which centroids","type":"text"},{"text":" ","type":"text"},{"text":"carried it.","type":"text"}],"variants":[{"paths":["\/documentation\/yeofr\/yeofrsdk\/beginenrollmentverification(identity:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK":{"type":"topic","url":"\/documentation\/yeofr\/yeofrsdk","navigatorTitle":[{"kind":"identifier","text":"YEOFRSDK"}],"role":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK","title":"YEOFRSDK","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"YEOFRSDK","kind":"identifier"}],"abstract":[{"text":"YEOFR main entry point.","type":"text"}],"kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK/beginEnrollmentVerification(identity:)":{"url":"\/documentation\/yeofr\/yeofrsdk\/begin