{"kind":"symbol","identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginEnrollmentVerification(identity:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK"]]},"metadata":{"title":"beginEnrollmentVerification(identity:)","role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"beginEnrollmentVerification"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identity"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","kind":"typeIdentifier","text":"FRSDKReturnCode"}],"externalID":"s:5YEOFR8YEOFRSDKC27beginEnrollmentVerification8identityAA15FRSDKReturnCodeOSS_tF","modules":[{"name":"YEOFR"}],"roleHeading":"Instance Method"},"abstract":[{"type":"text","text":"Phase 2 of the two-phase enrolment contract: arm the verification"},{"type":"text","text":" "},{"type":"text","text":"walk for a just-enrolled (in-memory, not yet persisted) identity."},{"type":"text","text":" "},{"type":"text","text":"Subsequent single-face, valid-framing recognition frames are"},{"type":"text","text":" "},{"type":"text","text":"scored against its gallery; "},{"type":"codeVoice","code":"enrollmentVerificationStatus"},{"type":"text","text":" reports"},{"type":"text","text":" "},{"type":"text","text":"live progress and, at "},{"type":"codeVoice","code":"finishEnrollmentVerification()"},{"type":"text","text":" (or the"},{"type":"text","text":" "},{"type":"text","text":"~60 s budget), the walk’s FRR evidence —"},{"type":"text","text":" "},{"type":"codeVoice","code":"recognizedFrames \/ framesVerified"},{"type":"text","text":" is the enrolment’s measured"},{"type":"text","text":" "},{"type":"text","text":"live recogni