{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/yeofrsdk\/beginenrollmentverification(identity:)"]}],"abstract":[{"type":"text","text":"Phase 2 of the two-phase enrolment contract: arm the verification"},{"type":"text","text":" "},{"type":"text","text":"walk for a just-enrolled (in-memory, not yet persisted) identity."},{"type":"text","text":" "},{"type":"text","text":"Subsequent single-face, valid-framing recognition frames are"},{"type":"text","text":" "},{"type":"text","text":"scored against its gallery; "},{"type":"codeVoice","code":"enrollmentVerificationStatus"},{"type":"text","text":" reports"},{"type":"text","text":" "},{"type":"text","text":"live progress and, at "},{"type":"codeVoice","code":"finishEnrollmentVerification()"},{"type":"text","text":" (or the"},{"type":"text","text":" "},{"type":"text","text":"~60 s budget), the walk’s FRR evidence —"},{"type":"text","text":" "},{"type":"codeVoice","code":"recognizedFrames \/ framesVerified"},{"type":"text","text":" is the enrolment’s measured"},{"type":"text","text":" "},{"type":"text","text":"live recognition rate, "},{"type":"codeVoice","code":"centroidHitCounts"},{"type":"text","text":" shows which centroids"},{"type":"text","text":" "},{"type":"text","text":"carried it."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginEnrollmentVerification(identity:)"},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/YEOFRSDK"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginEnrollmentVerification","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identity","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"FRSDKReturnCode","kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FRSDKReturnCode"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The walk also PATCHES the gaps it measures: an FRR moment (the","type":"text"},{"text":" ","type":"text"},{"text":"gallery fails the live user) feeds the rejected-positive capture","type":"text"},{"text":" ","type":"text"},{"text":"pipeline — accumulate, vet (consistency 0.90), guard (anchor 0.70","type":"text"},{"type":"text","text":" "},{"type":"text","text":"walk-1 parity, cross-identity, novelty) — and the staged centroids"},{"type":"text","text":" "},{"type":"text","text":"are appended to the in-memory gallery at finish, so the host’s"},{"type":"text","text":" "},{"type":"text","text":"post-walk persist saves the patched gallery ("},{"type":"codeVoice","code":"centroidsAdded"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"type":"codeVoice","code":"galleryCount"},{"text":" on the outcome; ","type":"text"},{"type":"codeVoice","code":"rescuedFrames"},{"text":" counts the frames a","type":"text"},{"text":" ","type":"text"},{"text":"patch covered live). The measured FRR is always scored against the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"original gallery — patches never inflate it. Cancel discards the"},{"text":" ","type":"text"},{"type":"text","text":"patches."}]},{"inlineContent":[{"type":"text","text":"Hosts should run this between gallery completion and persisting"},{"type":"text","text":" "},{"type":"text","text":"the tracker, surface the rate to the user, and persist regardless"},{"type":"text","text":" "},{"type":"text","text":"of the result (recommend a re-enrol on a low unpatched rate rather"},{"type":"text","text":" "},{"type":"text","text":"than failing the save — reject loops strand users)."},{"text":" ","type":"text"},{"type":"text","text":"Returns "},{"type":"codeVoice","code":".trackerIsNull"},{"type":"text","text":" when the identity isn’t enrolled or"},{"type":"text","text":" "},{"type":"text","text":"another session owns the embedding feed (also the constant return"},{"type":"text","text":" "},{"type":"text","text":"for engines without the verification walk, e.g. Luxand)."}],"type":"paragraph"}]}],"metadata":{"symbolKind":"method","modules":[{"name":"YEOFR"}],"externalID":"s:5YEOFR8YEOFRSDKC27beginEnrollmentVerification8identityAA15FRSDKReturnCodeOSS_tF","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginEnrollmentVerification","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identity","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") -> ","kind":"text"},{"text":"FRSDKReturnCode","kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO"}],"roleHeading":"Instance Method","title":"beginEnrollmentVerification(identity:)"},"references":{"doc://com.yeomessaging.YEOFR/documentation/YEOFR/YEOFRSDK":{"title":"YEOFRSDK","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"YEOFRSDK"}],"url":"\/documentation\/yeofr\/yeofrsdk","navigatorTitle":[{"kind":"identifier","text":"YEOFRSDK"}],"abstract":[{"text":"YEOFR main entry point.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/YEOFRSDK"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/FRSDKReturnCode":{"role":"symbol","title":"FRSDKReturnCode","navigatorTitle":[{"text":"FRSDKReturnCode","kind":"identifier"}],"abst