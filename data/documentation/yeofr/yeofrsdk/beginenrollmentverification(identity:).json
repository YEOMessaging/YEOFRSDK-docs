{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginEnrollmentVerification(identity:)"},"abstract":[{"text":"Phase 2 of the two-phase enrolment contract: arm the verification","type":"text"},{"text":" ","type":"text"},{"text":"walk for a just-enrolled (in-memory, not yet persisted) identity.","type":"text"},{"text":" ","type":"text"},{"text":"Subsequent single-face, valid-framing recognition frames are","type":"text"},{"text":" ","type":"text"},{"text":"scored against its gallery; ","type":"text"},{"code":"enrollmentVerificationStatus","type":"codeVoice"},{"text":" reports","type":"text"},{"text":" ","type":"text"},{"text":"live progress and, at ","type":"text"},{"code":"finishEnrollmentVerification()","type":"codeVoice"},{"text":" (or the","type":"text"},{"text":" ","type":"text"},{"text":"~60 s budget), the walk’s FRR evidence —","type":"text"},{"text":" ","type":"text"},{"code":"recognizedFrames \/ framesVerified","type":"codeVoice"},{"text":" is the enrolment’s measured","type":"text"},{"text":" ","type":"text"},{"text":"live recognition rate, ","type":"text"},{"code":"centroidHitCounts","type":"codeVoice"},{"text":" shows which centroids","type":"text"},{"text":" ","type":"text"},{"text":"carried it.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"beginEnrollmentVerification","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identity","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{