e","code":"galleryCount"},{"type":"text","text":" on the outcome; "},{"type":"codeVoice","code":"rescuedFrames"},{"type":"text","text":" counts the frames a"},{"type":"text","text":" "},{"type":"text","text":"patch covered live). The measured FRR is always scored against the"},{"type":"text","text":" "},{"type":"text","text":"original gallery — patches never inflate it. Cancel discards the"},{"type":"text","text":" "},{"type":"text","text":"patches."}]},{"type":"paragraph","inlineContent":[{"text":"Hosts should run this between gallery completion and persisting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the tracker, surface the rate to the user, and persist regardless"},{"text":" ","type":"text"},{"type":"text","text":"of the result (recommend a re-enrol on a low unpatched rate rather"},{"type":"text","text":" "},{"type":"text","text":"than failing the save — reject loops strand users)."},{"type":"text","text":" "},{"text":"Returns ","type":"text"},{"type":"codeVoice","code":".trackerIsNull"},{"text":" when the identity isn’t enrolled or","type":"text"},{"text":" ","type":"text"},{"text":"another session owns the embedding feed (also the constant return","type":"text"},{"type":"text","text":" "},{"text":"for engines without the verification walk, e.g. Luxand).","type":"text"}]}],"kind":"content"}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK/beginEnrollmentVerification(identity:)":{"role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Phase 2 of the two-phase enrolment contract: arm the verification"},{"type":"text","text":" "},{"type":"text","text":"walk for a just-enrolled (in-memory, not yet persisted) identity."},{"type":"text","text":" "},{"type":"text","text":"Subsequent single-face, valid-framing recognition frames are"},{"type":"text","text":" "},{"type":"text","text":"scored against its gallery; "},{"type":"codeVoice","code":"enrollmentVerificationStatus"},{"type":"text","text":" reports"},{"type":"text","text":" "},{"type":"text","text":"live progress and, at "},{"type":"codeVoice","code":"finishEnrollmentVerification()"},{"type":"text","text":" (or the"},{"type":"text","text":" "},{"type":"text","text":"~60 s budget), the walk’s FRR evidence —"},{"type":"text","text":" "},{"type":"codeVoice","code":"recognizedFrames \/ framesVerified"},{"type":"text","text":" is the enrolment’s measured"},{"type":"text","text":" "},{"type":"text","text":"live recognition rate, "},{"type":"codeVoice","code":"centroidHitCounts"},{"type":"text","text":" shows which centroids"},{"type":"text","text":" "},{"type":"text","text":"carried it."}],"title":"beginEnrollmentVerification(identity:)","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK\/beginEnrollmentVerification(identity:)","url":"\/documentation\/yeofr\/yeofrsdk\/beginenrollmentverification(identity:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"beginEnrollmentVerification"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identity"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:5YEOFR15FRSDKReturnCodeO","kind":"typeIdentifier","text":"FRSDKReturnCode"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/YEOFRSDK":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/YEOFRSDK","title":"YEOFRSDK","kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/yeofr\/yeofrsdk","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"YEOFRSDK"}],"abstract":[{"text":"YEOFR main entry point.","type":"text"}],"navigatorTitle":[{"text":"YEOFRSDK","kind":"identifier"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FRSDKReturnCode":{"title":"FRSDKReturnCode","kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.Y