{"variants":[{"paths":["\/documentation\/yeofr\/facetrustservice\/setfusionconfig(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Turn the fused anti-spoof signals on\/off at runtime: the liveness CNN"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"useLivenessSDK","type":"codeVoice"},{"type":"text","text":") and the TrueDepth 3D check ("},{"code":"useTrueDepthSDK","type":"codeVoice"},{"type":"text","text":"), plus"},{"type":"text","text":" "},{"type":"text","text":"the evidence\/depth knobs on "},{"type":"reference","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","isActive":true},{"type":"text","text":". Both signals"},{"type":"text","text":" "},{"type":"text","text":"default to ON ("},{"type":"reference","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionDefaults","isActive":true},{"type":"text","text":")."}],"identifier":{"url":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FaceTrustService\/setFusionConfig(_:)","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FaceTrustService"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setFusionConfig"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"config"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR26LivenessFusionConfigurableP","text":"LivenessFusionConfigurable","identifier":"doc:\/\