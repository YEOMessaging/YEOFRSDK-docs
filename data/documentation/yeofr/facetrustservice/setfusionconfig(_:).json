{"identifier":{"url":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FaceTrustService\/setFusionConfig(_:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FaceTrustService"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/facetrustservice\/setfusionconfig(_:)"]}],"abstract":[{"text":"Turn the fused anti-spoof signals on\/off at runtime: the liveness CNN","type":"text"},{"text":" ","type":"text"},{"text":"(","type":"text"},{"code":"useLivenessSDK","type":"codeVoice"},{"text":") and the TrueDepth 3D check (","type":"text"},{"code":"useTrueDepthSDK","type":"codeVoice"},{"type":"text","text":"), plus"},{"text":" ","type":"text"},{"text":"the evidence\/depth knobs on ","type":"text"},{"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","type":"reference","isActive":true},{"text":". Both signals","type":"text"},{"text":" ","type":"text"},{"text":"default to ON (","type":"text"},{"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionDefaults","type":"reference","isActive":true},{"text":").","type":"text"}],"metadata":{"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setFusionConfig"},{"kind":"text","text":"("},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR26LivenessFusionConfigurableP","text":"LivenessFusionConfigurable"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"}],"modules":[{"name":"YEOFR"}],"role":"symbol","symbolKind":"method","title":"setFusionConfig(_:)","externalID":"s:5YEOFR16FaceTrustServiceC15setFusionConfigyyxYaAA08LivenessF12ConfigurableRzlF"},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setFusionConfig","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"config","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:5YEOFR26LivenessFusionConfigurableP","text":"LivenessFusionConfigurable","kind":"typeIdentifier","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this to run FR-only, or FR + one signal, e.g. for compliance"},{"type":"text","text":" "},{"type":"text","text":"isolation or an A\/B. It forwards to the underlying "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FaceTrustSession"},{"type":"text","text":" "},{"type":"text","text":"and resets the trust state so the next frame re-evaluates cold — a live"},{"type":"text","text":" "},{"type":"text","text":"toggle otherwise leaves the previous verdict resident. Face recognition"},{"type":"text","text":" "},{"type":"text","text":"and the enrolled-identity gate are unaffected; this only governs which"},{"type":"text","text":" "},{"type":"text","text":"anti-spoof signals contribute to "},{"type":"codeVoice","code":"trusted"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Independent of "},{"code":"start(preferTrueDepth:)","type":"codeVoice"},{"type":"text","text":", which selects the camera"},{"type":"text","