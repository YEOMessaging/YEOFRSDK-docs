{"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService\/setFusionConfig(_:)","interfaceLanguage":"swift"},"sections":[],"variants":[{"paths":["\/documentation\/yeofr\/facetrustservice\/setfusionconfig(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Turn the fused anti-spoof signals on\/off at runtime: the liveness CNN"},{"text":" ","type":"text"},{"type":"text","text":"("},{"type":"codeVoice","code":"useLivenessSDK"},{"text":") and the TrueDepth 3D check (","type":"text"},{"code":"useTrueDepthSDK","type":"codeVoice"},{"type":"text","text":"), plus"},{"type":"text","text":" "},{"text":"the evidence\/depth knobs on ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable"},{"type":"text","text":". Both signals"},{"type":"text","text":" "},{"type":"text","text":"default to ON ("},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionDefaults"},{"type":"text","text":")."}],"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceTrustService"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setFusionConfig","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"config"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:5YEOFR26LivenessFusionConfigurableP","text":"LivenessFusionConfigurable","kind":"typeIdentifier","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documenta