"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/FaceFramingGateConfig":{"role":"symbol","abstract":[{"type":"text","text":"Thresholds used by "},{"type":"codeVoice","code":"FaceFramingGate.evaluate"},{"type":"text","text":". Lower + edge-pad"},{"type":"text","text":" "},{"type":"text","text":"defaults mirror Android ("},{"type":"codeVoice","code":"EngineWrapper.kt:95-103"},{"type":"text","text":"). The upper"},{"type":"text","text":" "},{"type":"text","text":"bound ("},{"type":"codeVoice","code":"maximumFaceWidthRatio"},{"type":"text","text":") is iOS-only: Android relies on"},{"type":"text","text":" "},{"type":"text","text":"the face actually crossing the edge to signal “too close”, but"},{"type":"text","text":" "},{"type":"text","text":"on an iPhone selfie camera the face usually fills most of the"},{"type":"text","text":" "},{"type":"text","text":"frame before any edge gets touched, so "},{"type":"codeVoice","code":".tooClose"},{"type":"text","text":" never fires"},{"type":"text","text":" "},{"type":"text","text":"and users get no feedback as they move the phone too near. A"},{"type":"text","text":" "},{"type":"text","text":"width-fraction ceiling gives the UX prompt a chance to appear"},{"type":"text","text":" "},{"type":"text","text":"before the rect escapes the frame entirely."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FaceFramingGateConfig"}],"url":"\/documentation\/yeofr\/faceframinggateconfig","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FaceFramingGateConfig"}],"title":"FaceFramingGateConfig","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/FaceFramingGateConfig","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"kind":"symbol","url":"\/documentation\/yeofr","title":"YEOFR","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","abstract":[{"type":"text","text":"A device-only face recognition SDK for iOS."}],"type":"topic","role":"collection"}}}