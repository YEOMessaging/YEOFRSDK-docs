{"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Type Property","symbolKind":"property","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"yawThreshold"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"externalID":"s:5YEOFR10PoseTargetO12yawThresholdSdvpZ","role":"symbol","modules":[{"name":"YEOFR"}],"title":"yawThreshold"},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget"]]},"kind":"symbol","abstract":[{"type":"text","text":"±7° in radians — the yaw turn-pose gate ("},{"type":"codeVoice","code":"yawLeft"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"yawRight"},{"type":"text","text":")."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"yawThreshold"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Narrowed in stages (±15° → ±10° → ±8° → ±7°): users reported having"},{"type":"text","text":" "},{"type":"text","text":"to “turn a lot” before a turn pose accepted. Vision’s yaw estimate"},{"type":"text","text":" "},{"type":"text","text":"compresses the physical rotation (the same effect documented for"},{"type":"text","text":" "},{"type":"text","text":"pitch below, milder on yaw), and at large physical turns Vision"},{"text":" ","type":"text"},{"text":"often drops yaw to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" — which disables the blind-Vision time","type":"text"},{"text":" ","type":"text"},{"text":"fallback (a readable angle was seen earlier in the pose), so the","type":"text"},{"text":" ","type":"text"},{"text":"pose can only clear via the ~10 s stall cap. Opening the matched","type":"text"},{"text":" ","type":"text"},{"text":"window at ±7° lets the hold accumulate at a smaller, more reliably","type":"text"},{"type":"text","text":" "},{"text":"readable angle. Still clears the ±5° ","type":"text"},{"code":"front","type":"codeVoice"},{"text":" zone with a 2° margin.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget\/yawthreshold"]}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/yawThreshold":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"yawThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"±7° in radians — the yaw turn-pose gate ("},{"code":"yawLeft","type":"codeVoice"},{"type":"text","text":" \/ "},{"code":"yawRight","type":"codeVoice"},{"type":"text","text":")."}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold","type":"topic","title":"yawThreshold","role":"symbol","url":"\/documentation\/yeofr\/posetarget\/yawthreshold","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget":{"title":"PoseTarget","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"PoseTarget","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com