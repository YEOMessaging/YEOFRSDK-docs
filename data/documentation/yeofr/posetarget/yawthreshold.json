ext"},{"text":"often drops yaw to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" — which disables the blind-Vision time","type":"text"},{"text":" ","type":"text"},{"text":"fallback (a readable angle was seen earlier in the pose), so the","type":"text"},{"text":" ","type":"text"},{"text":"pose can only clear via the ~10 s stall cap. Opening the matched","type":"text"},{"text":" ","type":"text"},{"text":"window at ±7° lets the hold accumulate at a smaller, more reliably","type":"text"},{"text":" ","type":"text"},{"text":"readable angle. Still clears the ±5° ","type":"text"},{"type":"codeVoice","code":"front"},{"text":" zone with a 2° margin.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget"]]},"references":{"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget/yawThreshold":{"type":"topic","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"yawThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold","abstract":[{"text":"±7° in radians — the yaw turn-pose gate (","type":"text"},{"code":"yawLeft","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"yawRight","type":"codeVoice"},{"text":").","type":"text"}],"role":"symbol","url":"\/documentation\/yeofr\/posetarget\/yawthreshold","title":"yawThreshold"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget":{"type":"topic","navigatorTitle":[{"text":"PoseTarget","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarg