{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget\/yawthreshold"]}],"abstract":[{"type":"text","text":"±7° in radians — the yaw turn-pose gate ("},{"type":"codeVoice","code":"yawLeft"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"yawRight"},{"type":"text","text":")."}],"sections":[],"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"YEOFR"}],"symbolKind":"property","role":"symbol","roleHeading":"Type Property","title":"yawThreshold","externalID":"s:5YEOFR10PoseTargetO12yawThresholdSdvpZ","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"yawThreshold","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}]},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"yawThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Narrowed in stages (±15° → ±10° → ±8° → ±7°): users reported having","type":"text"},{"text":" ","type":"text"},{"text":"to “turn a lot” before a turn pose accepted. Vision’s yaw estimate","type":"text"},{"text":" ","type":"text"},{"text":"compresses the physical rotation (the same effect documented for","type":"text"},{"text":" ","type":"text"},{"text":"pitch below, milder on yaw), and at large physical turns Vision","type":"text"},{"text":" ","type":"text"},{"text":"often drops yaw to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" — which disables the blind-Vision time","type":"text"},{"text":" ","type":"text"},{"text":"fallback (a readable angle was seen earlier in the pose), so the","type":"text"},{"text":" ","type":"text"},{"text":"pose can only clear via the ~10 s stall cap. Opening the matched","type":"text"},{"text":" ","type":"text"},{"text":"window at ±7° lets the hold accumulate at a smaller, more reliably","type":"text"},{"text":" ","type":"text"},{"text":"readable angle. Still clears the ±5° ","type":"text"},{"type":"codeVoice","code":"front"},{"text":" zone with a 2° margin.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","kind":"symbol","title":"YEOFR","url":"\/documentation\/yeofr","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"role":"collection","type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/yawThreshold":{"role":"symbol","title":"yawThreshold","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"yawThreshold"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold","kind":"symbol","type":"topic","url":"\/documentation\/yeofr\/posetarget\/yawthreshold","abstract":[{"type":"text","text":"±7° in radians — the yaw turn-pose gate ("},{"code":"yawLeft","type":"codeVoice"},{"type":"text","text":" \/ "},{"code":"yawRight","type":"codeVoice"},{"type":"