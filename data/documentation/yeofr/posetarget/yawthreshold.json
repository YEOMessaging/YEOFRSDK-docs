lder on yaw), and at large physical turns Vision","type":"text"},{"text":" ","type":"text"},{"text":"often drops yaw to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" — which disables the blind-Vision time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"fallback (a readable angle was seen earlier in the pose), so the"},{"type":"text","text":" "},{"type":"text","text":"pose can only clear via the ~10 s stall cap. Opening the matched"},{"type":"text","text":" "},{"type":"text","text":"window at ±7° lets the hold accumulate at a smaller, more reliably"},{"type":"text","text":" "},{"type":"text","text":"readable angle. Still clears the ±5° "},{"type":"codeVoice","code":"front"},{"type":"text","text":" zone with a 2° margin."}]}],"kind":"content"}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget/yawThreshold":{"title":"yawThreshold","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"yawThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold","type":"topic","role":"symbol","url":"\/documentation\/yeofr\/posetarget\/yawthreshold","abstract":[{"type":"text","text":"±7° in radians — the yaw turn-pose gate ("},{"code":"yawLeft","type":"codeVoice"},{"type":"text","text":" \/ "},{"code":"yawRight","type":"codeVoice"},{"type":"text","text":")."}]},"doc://com.yeomessaging.YEOFR/documentation/YEOFR":{"abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"role":"collection","type":"topic","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","title":"YEOFR","url":"\/documentation\/yeofr","kind":"symbol"},"doc://com.yeo