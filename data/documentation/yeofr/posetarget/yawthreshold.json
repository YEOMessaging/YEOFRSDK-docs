ch disables the blind-Vision time"},{"type":"text","text":" "},{"type":"text","text":"fallback (a readable angle was seen earlier in the pose), so the"},{"type":"text","text":" "},{"type":"text","text":"pose can only clear via the ~10 s stall cap. Opening the matched"},{"type":"text","text":" "},{"type":"text","text":"window at ±7° lets the hold accumulate at a smaller, more reliably"},{"type":"text","text":" "},{"type":"text","text":"readable angle. Still clears the ±5° "},{"type":"codeVoice","code":"front"},{"type":"text","text":" zone with a 2° margin."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"text":"±7° in radians — the yaw turn-pose gate (","type":"text"},{"type":"codeVoice","code":"yawLeft"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"yawRight"},{"text":").","type":"text"}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"url":"\/documentation\/yeofr","title":"YEOFR","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget":{"title":"PoseTarget","kind":"symbol","abstract":[{"type":"text","text":"Target head orientation for one slot of a gallery enrollment."}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","type":"topic","url":"\/documentation\/yeofr\/posetarget","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"navigatorTitle":[{"kind":"identifier","text":"PoseTarget"}],"role":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/yawThreshold":{"title":"yawThreshold","kind":"symbol","abstract":[{"type":"text","text":"±7° in radians — the yaw turn-pose gate ("},{"type":"codeVoice","code":"yawLeft"}