{"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget\/pitchthreshold"]}],"metadata":{"roleHeading":"Type Property","symbolKind":"property","externalID":"s:5YEOFR10PoseTargetO14pitchThresholdSdvpZ","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pitchThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"title":"pitchThreshold","modules":[{"name":"YEOFR"}]},"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"±4° in radians — the pitch turn-pose gate ("},{"type":"codeVoice","code":"pitchUp"},{"type":"text","text":" \/ "},{"code":"pitchDown","type":"codeVoice"},{"type":"text","text":")."}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"pitchThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Deliberately far below the yaw gate: Vision’s pitch estimate from the"},{"type":"text","text":" "},{"type":"text","text":"rectangles request COMPRESSES the physical angle massively. On-device"},{"type":"text","text":" "},{"type":"text","text":"(2026-06-11, iPhone