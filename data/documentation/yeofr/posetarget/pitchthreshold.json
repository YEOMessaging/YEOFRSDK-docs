eIdentifier":"s:Sd"}],"title":"pitchThreshold"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget":{"abstract":[{"type":"text","text":"Target head orientation for one slot of a gallery enrollment."}],"type":"topic","role":"symbol","kind":"symbol","title":"PoseTarget","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","url":"\/documentation\/yeofr\/posetarget","navigatorTitle":[{"kind":"identifier","text":"PoseTarget"}]}}}