{"hierarchy":{"paths":[["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget"]]},"kind":"symbol","identifier":{"url":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"pitchThreshold","modules":[{"name":"YEOFR"}],"externalID":"s:5YEOFR10PoseTargetO14pitchThresholdSdvpZ","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pitchThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"symbolKind":"property","roleHeading":"Type Property","role":"symbol"},"abstract":[{"type":"text","text":"±4° in radians — the pitch turn-pose gate ("},{"type":"codeVoice","code":"pitchUp"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"pitchDown"},{"type":"text","text":")."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget\/pitchthreshold"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"pitchThreshold"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Deliberately far below the yaw gate: Vision’s pitch estimate from the"},{"type":"text","text":" "},{"type":"text","text":"rectangles request COMPRESSES the physical angle massively. On-device"},{"type":"text","text":" "},{"type":"text","text":"(2026-06-11, iPhone front camera): a full, neck-straining chin-down"},{"type":"text","text":" "},{"type":"text","text":"hold reads only "},{"type":"strong","inlineContent":[{"text":"+6°","type":"text"}]},{"type":"text","text":", so the previous ±10° bar was physically"},{"type":"text","text":" "},{"type":"text","text":"unreachable and both pitch poses stalled the enrolment walk forever."},{"type":"text","text":" "},{"type":"text","text":"±5° cleared that full-tilt reading but only by ~1°, so with Vision’s"},{"type":"text","text":" "},{"type":"text","text":"pitch noise the hold rarely accumulated — the pitch poses still felt"},{"type":"text","text":" "},{"type":"text","text":"“too high”. Lowered to ±4° (2026-06-18) for ~2° of headroom below the"},{"type":"text","text":" "},{"text":"6° saturated reading, so most frames at a real tilt clear the gate.","type":"text"}],"type":"paragraph"}]}],"sections":[],"references":{"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget/pitchThreshold":{"title":"pitchThreshold","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pitchThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"url":"\/documentation\/yeofr\/posetarget\/pitchthreshold","abstract":[{"text":"±4° in radians — the pitch turn-pose gate (","type":"text"},{"code":"pitchUp","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"pitchDown","type":"codeVoice"},{"text":").","type":"text"}],"type":"topic","kind":"symbol"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR":{"abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"role":"collection","type":"topic","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","title":"YEOFR","url":"\/documentation\/yeofr","kind":"symbol"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget":{"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget","kind":"symbol","url":"\/documentation\/yeofr\/posetarget","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"abstract":[{"text":"Target head orientation for one slot of a gallery enrollment.","type":"text"}],"title":"PoseTarget","navigatorTitle":[{"kind":"identifier","text":"PoseTarget"}]}}}