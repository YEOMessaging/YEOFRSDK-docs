one front camera): a full, neck-straining chin-down","type":"text"},{"text":" ","type":"text"},{"text":"hold reads only ","type":"text"},{"inlineContent":[{"text":"+6°","type":"text"}],"type":"strong"},{"text":", so the previous ±10° bar was physically","type":"text"},{"text":" ","type":"text"},{"text":"unreachable and both pitch poses stalled the enrolment walk forever.","type":"text"},{"text":" ","type":"text"},{"text":"±5° cleared that full-tilt reading but only by ~1°, so with Vision’s","type":"text"},{"text":" ","type":"text"},{"text":"pitch noise the hold rarely accumulated — the pitch poses still felt","type":"text"},{"text":" ","type":"text"},{"text":"“too high”. Lowered to ±4° (2026-06-18) for ~2° of headroom below the","type":"text"},{"text":" ","type":"text"},{"text":"6° saturated reading, so most frames at a real tilt clear the gate.","type":"text"}]}]}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget":{"abstract":[{"type":"text","text":"Target head orientation for one slot of a gallery enrollment."}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","title":"PoseTarget","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"PoseTarget","kind":"identifier"}],"url":"\/documentation\/yeofr\/posetarget","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","kind":"symbol","title":"YEOFR","url":"\/documentation\/yeofr","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"role":"collection","type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/pitchThreshold":{"role":"symbol","title":"pitchThreshold","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text