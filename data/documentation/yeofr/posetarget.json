{"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"]}]},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"Used by the Luxand gallery walk to gate per-pose capture on the","type":"text"},{"text":" ","type":"text"},{"text":"user’s actual head orientation (Vision’s ","type":"text"},{"code":"VNFaceObservation.yaw","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"code":".pitch","type":"codeVoice"},{"text":"). Without this gate the SDK would auto-advance within ~50 ms","type":"text"},{"text":" ","type":"text"},{"text":"of pose acceptance — the user has no time to physically change","type":"text"},{"text":" ","type":"text"},{"text":"orientation, so every captured appearance reflects the same head","type":"text"},{"text":" ","type":"text"},{"text":"pose and the gallery gains no angular breadth.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Thresholds were picked to match the user’s normal head-turn range","type":"text"},{"text":" ","type":"text"},{"text":"during walking: ≈ ±15° on the off-axis targets, and a tight ±7° on","type":"text"},{"text":" ","type":"text"},{"code":".front","type":"codeVoice"},{"text":" so it only matches when the user is genuinely centred.","type":"text"},{"text":" ","type":"text"},{"text":"Vision reports yaw\/pitch in radians (≈ 0.26 rad per 15°).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Vision sign conventions","type":"text"}]},{"text":" on the rotated, mirrored front-camera","type":"text"},{"text":" ","type":"text"},{"text":"portrait buffer (","type":"text"},{"code":"VNFaceObservation","type":"codeVoice"},{"text":" reads geometry from the buffer","type":"text"},{"text":" ","type":"text"},{"text":"as-presented to Vision — the selfie mirror flips the apparent","type":"text"},{"text":" ","type":"text"},{"text":"rotation):","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"yaw","type":"text"}]},{"type":"text","text":": POSITIVE = head turned to the user’s LEFT (subject’s"},{"type":"text","text":" "},{"type":"text","text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the"},{"type":"text","text":" "},{"type":"text","text":"opposite of the world-frame “right turn = positive” convention"},{"type":"text","text":" "},{"type":"text","text":"because the front-camera buffer is mirror-imaged before Vision"},{"type":"text","text":" "},{"type":"text","text":"sees it."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"pitch","type":"text"}]},{"text":": positive = chin DOWN (face tilts towards the bottom","type":"text"},{"type":"text","text":" "},{"text":"of the rotated buffer), negative = chin UP. This is the opposite","type":"text"},{"text":" ","type":"text"},{"text":"of the colloquial “looking up = positive” convention.","type":"text"}],"type":"paragraph"}]}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"title":"Enrolment","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"],"anchor":"Enrolment"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget"]}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"roleHeading":"Enumeration","navigatorTitle":[{"text":"PoseTarget","kind":"identifier"}],"modules":[{"name":"YEOFR"}],"