/\/com.yeomessaging.YEOFR\/SE","title":"Swift.Encodable"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget/lightingAwareGallerySequence":{"abstract":[{"type":"text","text":"Gallery sequence that also spans lighting: after the 5 angular poses, a"},{"type":"text","text":" "},{"type":"text","text":"single trailing frontal pose runs the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"merged lighting phase"}]},{"type":"text","text":". Unlike an"},{"type":"text","text":" "},{"type":"text","text":"angular pose (one capture then advance), this phase keeps prompting the"},{"type":"text","text":" "},{"type":"text","text":"user to move into new light and captures appearances across distinct"},{"type":"text","text":" "},{"type":"text","text":"conditions until the lighting phase’s budget elapses."}],"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/lightingAwareGallerySequence","role":"symbol","url":"\/documentation\/yeofr\/posetarget\/lightingawaregallerysequence","kind":"symbol","type":"topic","title":"lightingAwareGallerySequence","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"lightingAwareGallerySequence"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","text":"PoseTarget","preciseIdentifier":"s:5YEOFR10PoseTargetO"},{"kind":"text","text":"]"}]},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget/pitchUp":{"abstract":[],"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchUp","role":"symbol","url":"\/documentation\/yeofr\/posetarget\/pitchup","kind":"symbol","title":"PoseTarget.pitchUp","type":"topic","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pitchUp","kind":"identifier"}]},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget/RawRepresentable-Implementations":{"title":"RawRepresentable Implementations","type":"to