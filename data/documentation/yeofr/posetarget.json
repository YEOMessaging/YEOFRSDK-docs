{"kind":"symbol","identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Target head orientation for one slot of a gallery enrollment."}],"metadata":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PoseTarget"}],"externalID":"s:5YEOFR10PoseTargetO","title":"PoseTarget","symbolKind":"enum","roleHeading":"Enumeration","modules":[{"name":"YEOFR"}],"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"seeAlsoSections":[{"anchor":"Enrolment","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"],"title":"Enrolment","generated":true}],"topicSections":[{"anchor":"Enumeration-Cases","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/front","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchDown","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchUp","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawLeft","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawRight"],"title":"Enumeration Cases","generated":true},{"anchor":"Initializers","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/init(rawValue:)"],"title":"Initializers","generated":true},{"anchor":"Instance-Methods","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/matches(yaw:pitch:)"],"title":"Instance Methods","generated":true},{"anchor":"Type-Properties","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/defaultGallerySequence","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/lightingAwareGallerySequence","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/offAxisThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/singleFront","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold"],"title":"Type Properties","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/Equatable-Implementations","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations"],"title":"Default Implementations","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Used by the Luxand gallery walk to gate per-pose capture on the","type":"text"},{"text":" ","type":"text"},{"text":"user’s actual head orientation (Vision’s ","type":"text"},{"code":"VNFaceObservation.yaw","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":".pitch"},{"text":"). Without this gate the SDK would auto-advance within ~50 ms","type":"text"},{"text":" ","type":"text"},{"text":"of pose acceptance — the user has no time to physically change","type":"text"},{"text":" ","type":"text"},{"text":"orientation, so every captured appearance reflects the same head","type":"text"},{"text":" ","type":"text"},{"text":"pose and the gallery gains no angular breadth.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thresholds were picked to match the user’s normal head-turn range"},{"type":"text","text":" "},{"type":"text","text":"during walking: a low ±7° on the yaw turn poses (Vision compresses"},{"type":"text","text":" "},{"type":"text","text":"physical head rotation, so a larger gate forces an exaggerated turn —"},{"text":" ","type":"text"},{"type":"text","text":"see "},{"code":"yawThreshold","type":"codeVoice"},{"text":"), and a tight ±5° on ","type":"text"},{"type":"codeVoice","code":".front"},{"type":"text","text":" so it only matches"},{"type":"text","text":" "},{"type":"text","text":"when the user is genuinely centred while still leaving a 2° dead-band"},{"type":"text","text":" "},{"type":"text","text":"below the yaw gate. Vision reports yaw\/pitch in radians (≈ 0.26 rad"},{"type":"text","text":" "},{"type":"text","text":"per 15°)."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Vision sign conventions","type":"text"}]},{"type":"text","text":" on the rotated, mirrored front-camera"},{"type":"text","text":" "},{"type":"text","text":"portrait buffer ("},{"type":"codeVoice","code":"VNFaceObservation"},{"type":"text","text":" reads geometry from the buffer"},{"type":"text","text":" "},{"type":"text","text":"as-presented to Vision — the selfie mirror flips the apparent"},{"type":"text","text":" "},{"type":"text","text":"rotation):"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"yaw","type":"text"}]},{"type":"text","text":": POSITIVE = head turned to the user’s LEFT (subject’s"},{"type":"text","text":" "},{"type":"text","text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the"},{"type":"text","text":" "},{"type":"text","text":"opposite of the world-frame “right turn = positive” convention"},{"type":"text","text":" "},{"type":"text","text":"because the front-camera buffer is mirror-imaged before Vision"},{"type":"text","text":" "},{"type":"text","text":"sees it."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"pitch","type":"text"}]},{"type":"text","text":": positive = chin DOWN (face tilts towards the bottom"},{"type":"text","text":" "},{"type":"text","text":"of the rotated buffer), negative = chin UP. This is the opposite"},{"type":"text","text":" "},{"type":"text","text":"of the colloquial “looking up = positive” convention."}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget"]}],"sections":[],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/Se","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SE","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SQ","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SH","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SY","doc:\/\/com.youreyeonly.yeofr.YEOFR\/s8SendableP","doc:\/\/com.youreyeonly.yeofr.YEOFR\/s16SendableMetatypeP"],"title":"Conforms To","type":"conformsTo"}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"url":"\/documentation\/yeofr","title":"YEOFR","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","kind":"symbol","role":"collection","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/SQ":{"title":"Swift.Equatable","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/SQ","type":"unresolvable"},"doc://com.youreyeonly.yeofr.YEOFR/SE":{"title":"Swift.Encodable","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/SE","type":"unresolvable"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/frontThreshold":{"title":"frontThreshold","kind":"symbol","abstract":[{"type":"text","text":"±5° in radians — "},{"type":"codeVoice","code":"front"},{"type":"text","text":" requires both axes inside this. Tightened"},{"type":"text",