,"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/lightingAwareGallerySequence","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/offAxisThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/singleFront","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/Equatable-Implementations","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations"]}],"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/yeofr\/posetarget"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Used by the Luxand gallery walk to gate per-pose capture on the"},{"type":"text","text":" "},{"type":"text","text":"user’s actual head orientation (Vision’s "},{"type":"codeVoice","code":"VNFaceObservation.yaw"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"type":"codeVoice","code":".pitch"},{"type":"text","text":"). Without this gate the SDK would auto-advance within ~50 ms"},{"type":"text","text":" "},{"type":"text","text":"of pose acceptance — the user has no time to physically change"},{"type":"text","text":" "},{"type":"text","text":"orientation, so every captured appearance reflects the same head"},{"type":"text","text":" "},{"type":"text","text":"pose and the gallery gains no angular breadth."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thresholds were picked to match the user’s normal head-turn range"},{"type":"text","text":" "},{"type":"text","text":"during walking: ≈ ±15° on the off-axis targets, and a tight ±7° on"},{"type":"text","text":" "},{"type":"codeVoice","code":".front"},{"type":"text","text":" so it only matches when the user is genuinely centred."},{"type":"text","text":" "},{"type":"text","text":"Vision reports yaw\/pitch in radians (≈ 0.26 rad per 15°)."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Vision sign conventions","type":"text"}]},{"type":"text","text":" on the rotated, mirrored front-camera"},{"type":"text","text":" "},{"type":"text","text":"portrait buffer ("},{"type":"codeVoice","code":"VNFaceObservation"},{"type":"text","text":" reads geometry from the buffer"},{"type":"text","text":" "},{"type":"text","text":"as-presented to Vision — the selfie mirror flips the apparent"},{"type":"text","text":" "},{"type":"text","text":"rotation):"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"yaw","type":"text"}],"type":"strong"},{"type":"text","text":": POSITIVE = head turned to the user’s LEFT (subject’s"},{"type":"text","text":" "},{"type":"text","text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the"},{"type":"text","text":" "},{"type":"text","text":"opposite of the world-frame “right turn = positive” convention"},{"type":"text","text":" "},{"type":"text","text":"because the front-camera buffer is mirror-imaged before Vision"},{"type":"text","text":" "},{"type":"text","text":"sees it."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"pitch","type":"text"}],"type":"strong"},{"type":"text","text":": positive = chin DOWN (face tilts towards the bottom"},{"type":"text","text":" "},{"type":"text","text":"of the rotated buffer), negative = chin UP. This is the opposite"},{"type":"text","text":" "},{"type":"text","text":"of the colloquial “looking up = positive” convention."}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/frontThreshold":{"abstract":[{"type":"text","text":"±7° in radians — "},{"type":"codeVoice","code":"front"},{"type":"text","text":" requires both axes inside this."}],"kind":"symbol","title":"frontThreshold","role":"symbol","type":"topic","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"frontThreshold"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"url":"\/documentation\/yeofr\/posetarget\/frontthreshold"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/RawRepresentable-Implementations":{"abstract":[],"kind":"article","title":"RawRepresentable Implementations","role":"collectionGroup","type":"topic","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations","url":"\/documentation\/yeofr\/posetarget\/rawrepresentable-implementations"},"doc://com.youreyeonly.yeofr.YEOFR/s16SendableMetatypeP":{"type":"unresolvable","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/s16SendableMetatypeP","title":"Swift.SendableMetatype"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/singleFront":{"abstract":[{"type":"text","text":"Single-pose fallback (back-compat for "},{"type":"codeVoice","code":"enroll(faceID:name:)"},{"type":"text","text":")."}],"kind":"