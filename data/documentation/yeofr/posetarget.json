{"hierarchy":{"paths":[["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR"]]},"relationshipsSections":[{"identifiers":["doc:\/\/com.yeomessaging.YEOFR\/Se","doc:\/\/com.yeomessaging.YEOFR\/SE","doc:\/\/com.yeomessaging.YEOFR\/SQ","doc:\/\/com.yeomessaging.YEOFR\/SH","doc:\/\/com.yeomessaging.YEOFR\/SY","doc:\/\/com.yeomessaging.YEOFR\/s8SendableP","doc:\/\/com.yeomessaging.YEOFR\/s16SendableMetatypeP"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"kind":"symbol","identifier":{"url":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"PoseTarget"}],"modules":[{"name":"YEOFR"}],"title":"PoseTarget","externalID":"s:5YEOFR10PoseTargetO","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"symbolKind":"enum","roleHeading":"Enumeration","role":"symbol"},"abstract":[{"text":"Target head orientation for one slot of a gallery enrollment.","type":"text"}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/front","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchDown","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchUp","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawLeft","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawRight"],"anchor":"Enumeration-Cases","title":"Enumeration Cases"},{"generated":true,"identifiers":["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/init(rawValue:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/matches(yaw:pitch:)"],"anchor":"Instance-Methods","title":"Instance Methods"},{"generated":true,"identifiers":["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/defaultGallerySequence","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/lightingAwareGallerySequence","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/offAxisThreshold","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/singleFront","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold"],"anchor":"Type-Properties","title":"Type Properties"},{"generated":true,"identifiers":["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/Equatable-Implementations","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/EnrollmentProgress","doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"],"anchor":"Enrolment","title":"Enrolment"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"text":"Used by the Luxand gallery walk to gate per-pose capture on the","type":"text"},{"text":" ","type":"text"},{"text":"user’s actual head orientation (Vision’s ","type":"text"},{"code":"VNFaceObservation.yaw","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"code":".pitch","type":"codeVoice"},{"text":"). Without this gate the SDK would auto-advance within ~50 ms","type":"text"},{"text":" ","type":"text"},{"text":"of pose acceptance — the user has no time to physically change","type":"text"},{"text":" ","type":"text"},{"text":"orientation, so every captured appearance reflects the same head","type":"text"},{"text":" ","type":"text"},{"text":"pose and the gallery gains no angular breadth.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Thresholds were picked to match the user’s normal head-turn range","type":"text"},{"text":" ","type":"text"},{"text":"during walking: a low ±7° on the yaw turn poses (Vision compresses","type":"text"},{"text":" ","type":"text"},{"text":"physical head rotation, so a larger gate forces an exaggerated turn —","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"type":"codeVoice","code":"yawThreshold"},{"text":"), and a tight ±5° on ","type":"text"},{"type":"codeVoice","code":".front"},{"text":" so it only matches","type":"text"},{"text":" ","type":"text"},{"text":"when the user is genuinely centred while still leaving a 2° dead-band","type":"text"},{"text":" ","type":"text"},{"text":"below the yaw gate. Vision reports yaw\/pitch in radians (≈ 0.26 rad","type":"text"},{"text":" ","type":"text"},{"text":"per 15°).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Vision sign conventions"}],"type":"strong"},{"type":"text","text":" on the rotated, mirrored front-camera"},{"type":"text","text":" "},{"type":"text","text":"portrait buffer ("},{"type":"codeVoice","code":"VNFaceObservation"},{"type":"text","text":" reads geometry from the buffer"},{"type":"text","text":" "},{"type":"text","text":"as-presented to Vision — the selfie mirror flips the apparent"},{"type":"text","text":" "},{"type":"text","text":"rotation):"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"type":"text","text":"yaw"}],"type":"strong"},{"text":": POSITIVE = head turned to the user’s LEFT (subject’s","type":"text"},{"text":" ","type":"text"},{"text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the","type":"text"},{"text":" ","type":"text"},{"text":"opposite of the world-frame “right turn = positive” convention","type":"text"},{"text":" ","type":"text"},{"text":"because the front-camera buffer is mirror-imaged before Vision","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"sees it."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"pitch","type":"text"}]},{"type":"text","text":": positive = chin DOWN (face tilts towards the bottom"},{"type":"text","text":" "},{"type":"text","text":"of the rotated buffer), negative = chin UP. This is the opposite"},{"type":"text","text":" "},{"type":"text","text":"of the colloquial “looking up = positive” convention."}]}]}]}],"kind":"content"}],"sections":[],"references":{"doc://com.yeomessaging.YEOFR/documentation/YEOFR/PoseTarget/yawRight":{"type":"topic","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawRight","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"yawRight","kind":"identifier"}],"url":"\/documentation\/yeofr\/posetarget\/yawright","abstract":[],"kind":"symbol","title":"PoseTarget.yawRight"},"doc://com.yeomessaging.YEOFR/SQ":{"identifier":"doc:\/\/com.yeomessaging.YEOFR\/SQ","title":"Swift.Equatable","type":"unresolvable"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/FaceTrustService/enroll(name:poses:)":{"title":"enroll(name:poses:)","role":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/FaceTrustService\/enroll(name:poses:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"enroll"},{"kind":"text","text":"("},{"kind":"externalParam","text":"name"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentif