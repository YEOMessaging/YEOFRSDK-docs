youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/offAxisThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/singleFront","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold"],"anchor":"Type-Properties","title":"Type Properties","generated":true},{"identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/Equatable-Implementations","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"relationshipsSections":[{"identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/Se","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SE","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SQ","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SH","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SY","doc:\/\/com.youreyeonly.yeofr.YEOFR\/s8SendableP","doc:\/\/com.youreyeonly.yeofr.YEOFR\/s16SendableMetatypeP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"],"anchor":"Enrolment","title":"Enrolment","generated":true}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Used by the Luxand gallery walk to gate per-pose capture on the"},{"type":"text","text":" "},{"type":"text","text":"user’s actual head orientation (Vision’s "},{"code":"VNFaceObservation.yaw","type":"codeVoice"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"code":".pitch","type":"codeVoice"},{"type":"text","text":"). Without this gate the SDK would auto-advance within ~50 ms"},{"type":"text","text":" "},{"type":"text","text":"of pose acceptance — the user has no time to physically change"},{"type":"text","text":" "},{"type":"text","text":"orientation, so every captured appearance reflects the same head"},{"type":"text","text":" "},{"type":"text","text":"pose and the gallery gains no angular breadth."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thresholds were picked to match the user’s normal head-turn range"},{"type":"text","text":" "},{"type":"text","text":"during walking: a low ±7° on the yaw turn poses (Vision compresses"},{"type":"text","text":" "},{"type":"text","text":"physical head rotation, so a larger gate forces an exaggerated turn —"},{"type":"text","text":" "},{"type":"text","text":"see "},{"code":"yawThreshold","type":"codeVoice"},{"type":"text","text":"), and a tight ±5° on "},{"code":".front","type":"codeVoice"},{"type":"text","text":" so it only matches"},{"type":"text","text":" "},{"type":"text","text":"when the user is genuinely centred while still leaving a 2° dead-band"},{"type":"text","text":" "},{"type":"text","text":"below the yaw gate. Vision reports yaw\/pitch in radians (≈ 0.26 rad"},{"type":"text","text":" "},{"type":"text","text":"per 15°)."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Vision sign conventions"}]},{"type":"text","text":" on the rotated, mirrored front-camera"},{"type":"text","text":" "},{"type":"text","text":"portrait buffer ("},{"code":"VNFaceObservation","type":"codeVoice"},{"type":"text","text":" reads geometry from the buffer"},{"type":"text","text":" "},{"type":"text","text":"as-presented to Vision — the selfie mirror flips the apparent"},{"type":"text","text":" "},{"type":"text","text":"rotation):"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"yaw"}]},{"text":": POSITIVE = head turned to the user’s LEFT (subject’s","type":"text"},{"text":" ","type":"text"},{"text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the","type":"text"},{"text":" ","type":"text"},{"text":"opposite of the world-frame “right turn = positive” convention","type":"text"},{"text":" ","type":"text"},{"text":"because the front-camera buffer is mirror-imaged before Vision","type":"text"},{"text":" ","type":"text"},{"text":"sees it.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"pitch"}]},{"text":": positive = chin DOWN (face tilts towards the bottom","type":"text"},{"text":" ","type":"text"},{"text":"of the rotated buffer), negative = chin UP. This is the opposite","type":"text"},{"text":" ","type":"text"},{"text":"of the colloquial “looking up = positive” convention.","type":"text"}]}]}]}],"kind":"content"}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/offAxisThreshold":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/offAxisThreshold","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"offAxisThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"kind":"symbol","role":"symbol","url":"\/documentation\/yeofr\/posetarget\/offaxisthreshold","title":"offAxisThreshold","type":"topic","abstract":[{"type":"text","text":"±15° in radians. The relaxed frontal tolerance the lighting pass uses"},{"type":"text","text":" "},{"type":"text","text":"(stay roughly frontal while moving through light) — NOT the turn-pose"},{"type":"text","text":" "},{"type":"text","text":"gate, which uses the narrower "},{"code":"yawThreshold","type":"codeVoice"},{"type":"text","text":"."}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/frontThreshold":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"frontThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"kind":"symbol","role":"symbol","url":"\/documentation\/yeofr\/posetarget\/frontthreshold","title":"frontThreshold","type":"topic","abstract":[{"type":"text","text":"±5° in radians — "},{"code":"front","type":"codeVoice"},{"type":"text","text":" requires both axes inside this. Tightened"},{"type":"text","text":" "},{"type":"text","text":"from ±7° to leave a 2° dead-band below the ±7° "},{"code":"yawThreshold","type":"codeVoice"},{"type":"text","text":" so a"},{"type":"text","text":" "},{"type":"text","text":"centred "},{"code":"front","type":"codeVoice"},{"type":"text","text":" and a "},{"code":"yawLeft","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"yawRight","type":"codeVoice"},{"type":"text","text":" turn stay separable."}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"abstract":[{"text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing.","type":"text"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","type":"topic","title":"YEOFR","role":"collection","url":"\/documentation\/yeofr","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/lightingAwareGallerySequence":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/lightingAwareGallerySequence","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"lightingAwareGallerySequence","kin