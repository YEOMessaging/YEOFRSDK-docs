{"metadata":{"roleHeading":"Enumeration","externalID":"s:5YEOFR10PoseTargetO","symbolKind":"enum","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PoseTarget"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"title":"PoseTarget","modules":[{"name":"YEOFR"}]},"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/Se","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SE","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SQ","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SH","doc:\/\/com.youreyeonly.yeofr.YEOFR\/SY","doc:\/\/com.youreyeonly.yeofr.YEOFR\/s8SendableP","doc:\/\/com.youreyeonly.yeofr.YEOFR\/s16SendableMetatypeP"],"kind":"relationships"}],"identifier":{"url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR"]]},"topicSections":[{"identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/front","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchDown","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchUp","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawLeft","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawRight"],"title":"Enumeration Cases","generated":true,"anchor":"Enumeration-Cases"},{"title":"Initializers","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/init(rawValue:)"],"anchor":"Initializers","generated":true},{"anchor":"Instance-Methods","generated":true,"identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/matches(yaw:pitch:)"],"title":"Instance Methods"},{"anchor":"Type-Properties","generated":true,"title":"Type Properties","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/defaultGallerySequence","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/lightingAwareGallerySequence","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/offAxisThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/singleFront","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold"]},{"anchor":"Default-Implementations","generated":true,"title":"Default Implementations","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/Equatable-Implementations","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations"]}],"abstract":[{"type":"text","text":"Target head orientation for one slot of a gallery enrollment."}],"seeAlsoSections":[{"anchor":"Enrolment","generated":true,"title":"Enrolment","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"languages":["swift"],"platforms":["iOS","iPadOS","Mac Catalyst"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Used by the Luxand gallery walk to gate per-pose capture on the","type":"text"},{"text":" ","type":"text"},{"text":"user’s actual head orientation (Vision’s ","type":"text"},{"code":"VNFaceObservation.yaw","type":"codeVoice"},{"text":" \/","type":"text"},{"text":" ","type":"text"},{"code":".pitch","type":"codeVoice"},{"text":"). Without this gate the SDK would auto-advance within ~50 ms","type":"text"},{"text":" ","type":"text"},{"text":"of pose acceptance — the user has no time to physically change","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"orientation, so every captured appearance reflects the same head"},{"type":"text","text":" "},{"type":"text","text":"pose and the gallery gains no angular breadth."}]},{"type":"paragraph","inlineContent":[{"text":"Thresholds were picked to match the user’s normal head-turn range","type":"text"},{"type":"text","text":" "},{"type":"text","text":"during walking: a low ±7° on the yaw turn poses (Vision compresses"},{"type":"text","text":" "},{"type":"text","text":"physical head rotation, so a larger gate forces an exaggerated turn —"},{"type":"text","text":" "},{"type":"text","text":"see "},{"code":"yawThreshold","type":"codeVoice"},{"type":"text","text":"), and a tight ±5° on "},{"code":".front","type":"codeVoice"},{"type":"text","text":" so it only matches"},{"type":"text","text":" "},{"type":"text","text":"when the user is genuinely centred while still leaving a 2° dead-band"},{"type":"text","text":" "},{"type":"text","text":"below the yaw gate. Vision reports yaw\/pitch in radians (≈ 0.26 rad"},{"type":"text","text":" "},{"type":"text","text":"per 15°)."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Vision sign conventions"}]},{"type":"text","text":" on the rotated, mirrored front-camera"},{"type":"text","text":" "},{"type":"text","text":"portrait buffer ("},{"code":"VNFaceObservation","type":"codeVoice"},{"type":"text","text":" reads geometry from the buffer"},{"type":"text","text":" "},{"type":"text","text":"as-presented to Vision — the selfie mirror flips the apparent"},{"type":"text","text":" "},{"type":"text","text":"rotation):"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"yaw","type":"text"}]},{"text":": POSITIVE = head turned to the user’s LEFT (subject’s","type":"text"},{"text":" ","type":"text"},{"text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the","type":"text"},{"text":" ","type":"text"},{"text":"opposite of the world-frame “right turn = positive” convention","type":"text"},{"text":" ","type":"text"},{"text":"because the front-camera buffer is mirror-imaged before Vision","type":"text"},{"text":" ","type":"text"},{"text":"sees it.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"pitch","type":"text"}]},{"text":": positive = chin DOWN (face tilts towards the bottom","type":"text"},{"text":" ","type":"text"},{"text":"of the rotated buffer), negative = chin UP. This is the opposite","type":"text"},{"text":" ","type":"text"},{"text":"of the colloquial “looking up = positive” convention.","type":"text"}],"type":"paragraph"}]}]}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget"]}],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/RawRepresentable-Implementations":{"type":"topic","url":"\/documentation\/yeofr\/posetarget\/rawrepresentable-implementations","role":"collectionGroup","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations","title":"RawRepresentable Implementations","abstract":[],"kind":"article"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/lightingAwareGallerySequence":{"url":"\/documentation\/yeofr\/posetarget\/lightingawaregallerysequence","type":"topic","role":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/lightingAwareGallerySequence","title":"lightingAwareGallerySequence","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"lightingAwareGallerySequence","kind":"identifier"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:5YEOFR10PoseTargetO","text":"PoseTarget"},{"text":"]","kind":"text"}],"abstract":[{"type":"text","text":"Gallery sequence that also spans lighting: after the 5 angular poses, a"},{"type":"text","text":" "},{"type":"text","text":"single trailing frontal pose runs the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"merged lighting phase"}]},{"type":"text","text":". Unlike an"},{"type":"text","text":" "},{"type":"text","text":"angular pose (one capture then advance), this phase keeps prompting the"},{"type":"text","text":" "},{"type":"text","text":"user to move into new light and captures appearances across distinct"},{"type":"text","text":" "},{"type":"text","text":"conditions until the lighting phase’s budget elapses."}],"kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LightingPhaseConfig":{"url":"\/documentation\/yeofr\/lightingphaseconfig","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LightingPhaseConfig"}],"role":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig","title":"LightingPhaseConfig","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightingPhaseConfig","kind":"identifier"}],"abstract":[{"type":"text","text":"Termination policy for the merged lighting phase — how long the"},{"type":"text","text":" "},{"type":"text","text":"trailing-front “find new light” hunt runs and what ends it."}],"kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/yawRight":{"type":"topic","abstract":[],"role":"symbol","kind":"symbol","title":"PoseTarget.yawRight","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"yawRight"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawRight","url":"\/documentation\/yeofr\/posetarget