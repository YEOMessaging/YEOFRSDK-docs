{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"languages":["swift"],"platforms":["iOS","iPadOS","Mac Catalyst"]}]},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Used by the Luxand gallery walk to gate per-pose capture on the"},{"type":"text","text":" "},{"type":"text","text":"user’s actual head orientation (Vision’s "},{"type":"codeVoice","code":"VNFaceObservation.yaw"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"code":".pitch","type":"codeVoice"},{"text":"). Without this gate the SDK would auto-advance within ~50 ms","type":"text"},{"text":" ","type":"text"},{"text":"of pose acceptance — the user has no time to physically change","type":"text"},{"text":" ","type":"text"},{"text":"orientation, so every captured appearance reflects the same head","type":"text"},{"text":" ","type":"text"},{"text":"pose and the gallery gains no angular breadth.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thresholds were picked to match the user’s normal head-turn range"},{"type":"text","text":" "},{"type":"text","text":"during walking: a low ±7° on the yaw turn poses (Vision compresses"},{"text":" ","type":"text"},{"text":"physical head rotation, so a larger gate forces an exaggerated turn —","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"see "},{"type":"codeVoice","code":"yawThreshold"},{"type":"text","text":"), and a tight ±5° on "},{"code":".front","type":"codeVoice"},{"text":" so it only matches","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when the user is genuinely centred while still leaving a 2° dead-band"},{"type":"text","text":" "},{"type":"text","text":"below the yaw gate. Vision reports yaw\/pitch in radians (≈ 0.26 rad"},{"type":"text","text":" "},{"type":"text","text":"per 15°)."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Vision sign conventions"}]},{"type":"text","text":" on the rotated, mirrored front-camera"},{"type":"text","text":" "},{"type":"text","text":"portrait buffer ("},{"type":"codeVoice","code":"VNFaceObservation"},{"type":"text","text":" reads geometry from the buffer"},{"type":"text","text":" "},{"type":"text","text":"as-presented to Vision — the selfie mirror flips the apparent"},{"type":"text","text":" "},{"type":"text","text":"rotation):"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"yaw","type":"text"}],"type":"strong"},{"text":": POSITIVE = head turned to the user’s LEFT (subject’s","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the"},{"type":"text","text":" "},{"type":"text","text":"opposite of the world-frame “right turn = positive” convention"},{"text":" ","type":"text"},{"type":"text","text":"because the front-camera buffer is mirror-imaged before Vision"},{"text":" ","type":"text"},{"text":"sees it.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"pitch","type":"text"}]},{"text":": positive = chin DOWN (face tilts towards the bottom","type":"text"},{"text":" ","type":"text"},{"text":"of the rotated buffer), negative = chin UP. This is the opposite","type":"text"},{"text":" ","type":"text"},{"text":"of the colloquial “looking up = positive” convention.","type":"text"}]}]}]}],"kind":"content"}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"s:5YEOFR10PoseTargetO","title":"PoseTarget","symbolKind":"enum","roleHeading":"Enumeration","navigatorTitle":[{"text":"PoseTarget","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"m