\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/yawThreshold"],"title":"Type Properties"},{"generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/Equatable-Implementations","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/RawRepresentable-Implementations"],"title":"Default Implementations"}],"seeAlsoSections":[{"generated":true,"anchor":"Enrolment","identifiers":["doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/EnrollmentProgress","doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig"],"title":"Enrolment"}],"metadata":{"role":"symbol","navigatorTitle":[{"text":"PoseTarget","kind":"identifier"}],"title":"PoseTarget","modules":[{"name":"YEOFR"}],"externalID":"s:5YEOFR10PoseTargetO","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}],"roleHeading":"Enumeration","symbolKind":"enum"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/yeofr\/posetarget"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"],"tokens":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PoseTarget","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Used by the Luxand gallery walk to gate per-pose capture on the"},{"type":"text","text":" "},{"type":"text","text":"user’s actual head orientation (Vision’s "},{"code":"VNFaceObservation.yaw","type":"codeVoice"},{"type":"text","text":" \/"},{"type":"text","text":" "},{"code":".pitch","type":"codeVoice"},{"type":"text","text":"). Without this gate the SDK would auto-advance within ~50 ms"},{"type":"text","text":" "},{"type":"text","text":"of pose acceptance — the user has no time to physically change"},{"type":"text","text":" "},{"type":"text","text":"orientation, so every captured appearance reflects the same head"},{"type":"text","text":" "},{"type":"text","text":"pose and the gallery gains no angular breadth."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Thresholds were picked to match the user’s normal head-turn range"},{"type":"text","text":" "},{"type":"text","text":"during walking: a low ±7° on the yaw turn poses (Vision compresses"},{"type":"text","text":" "},{"type":"text","text":"physical head rotation, so a larger gate forces an exaggerated turn —"},{"type":"text","text":" "},{"type":"text","text":"see "},{"code":"yawThreshold","type":"codeVoice"},{"type":"text","text":"), and a tight ±5° on "},{"code":".front","type":"codeVoice"},{"type":"text","text":" so it only matches"},{"type":"text","text":" "},{"type":"text","text":"when the user is genuinely centred while still leaving a 2° dead-band"},{"type":"text","text":" "},{"type":"text","text":"below the yaw gate. Vision reports yaw\/pitch in radians (≈ 0.26 rad"},{"type":"text","text":" "},{"type":"text","text":"per 15°)."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Vision sign conventions","type":"text"}]},{"type":"text","text":" on the rotated, mirrored front-camera"},{"type":"text","text":" "},{"type":"text","text":"portrait buffer ("},{"code":"VNFaceObservation","type":"codeVoice"},{"type":"text","text":" reads geometry from the buffer"},{"type":"text","text":" "},{"type":"text","text":"as-presented to Vision — the selfie mirror flips the apparent"},{"type":"text","text":" "},{"type":"text","text":"rotation):"}]},{"items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"yaw","type":"text"}],"type":"strong"},{"text":": POSITIVE = head turned to the user’s LEFT (subject’s","type":"text"},{"text":" ","type":"text"},{"text":"POV), NEGATIVE = head turned to the user’s RIGHT. This is the","type":"text"},{"text":" ","type":"text"},{"text":"opposite of the world-frame “right turn = positive” convention","type":"text"},{"text":" ","type":"text"},{"text":"because the front-camera buffer is mirror-imaged before Vision","type":"text"},{"text":" ","type":"text"},{"text":"sees it.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"inlineContent":[{"text":"pitch","type":"text"}],"type":"strong"},{"text":": positive = chin DOWN (face tilts towards the bottom","type":"text"},{"text":" ","type":"text"},{"text":"of the rotated buffer), negative = chin UP. This is the opposite","type":"text"},{"text":" ","type":"text"},{"text":"of the colloquial “looking up = positive” convention.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"abstract":[{"type":"text","text":"Target head orientation for one slot of a gallery enrollment."}],"sections":[],"references":{"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","kind":"symbol","title":"YEOFR","url":"\/documentation\/yeofr","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"role":"collection","type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/frontThreshold":{"role":"symbol","title":"frontThreshold","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"frontThreshold"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","kind":"symbol","type":"topic","url":"\/documentation\/yeofr\/posetarget\/frontthreshold","abstract":[{"type":"text","text":"±5° in radians — "},{"code":"front","type":"codeVoice"},{"type":"text","text":" requires both axes inside this. Tightened"},{"type":"text","text":" "},{"type":"text","text":"from ±7° to leave a 2° dead-band below the ±7° "},{"code":"yawThreshold","type":"codeVoice"},{"type":"text","text":" so a"},{"type":"text","text":" "},{"type":"text","text":"centred "},{"code":"front","type":"codeVoice"},{"type":"text","text":" and a "},{"code":"yawLeft","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"yawRight","type":"codeVoice"},{"type":"text","text":" turn stay separable."}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget":{"abstract":[{"type":"text","text":"Target head orientation for one slot of a gallery enrollment."}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget","title":"PoseTarget","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"PoseTarget","kind":"identifier"}],"url":"\/documentation\/yeofr\/posetarget","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PoseTarget"}],"type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/init(rawValue:)":{"role":"symbol","title":"init(rawValue:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"?("},{"kind":"externalParam","text":"rawValue"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":")"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/init(rawValue:)","kind":"symbol","type":"topic","url":"\/documentation\/yeofr\/posetarget\/init(rawvalue:)","abstract":[]},"doc://com.youreyeonly.yeofr.YEOFR/SE":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/SE","type":"unresolvable","title":"Swift.Encodable"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/matches(yaw:pitch:)":{"role":"symbol","title"