"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"abstract":[{"text":"True when the current head orientation matches this target.","type":"text"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LightingPhaseConfig":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LightingPhaseConfig","kind":"symbol","title":"LightingPhaseConfig","role":"symbol","type":"topic","url":"\/documentation\/yeofr\/lightingphaseconfig","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LightingPhaseConfig","kind":"identifier"}],"abstract":[{"text":"Termination policy for the merged lighting phase — how long the","type":"text"},{"text":" ","type":"text"},{"text":"trailing-front “find new light” hunt runs and what ends it.","type":"text"}],"navigatorTitle":[{"text":"LightingPhaseConfig","kind":"identifier"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/frontThreshold":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/frontThreshold","kind":"symbol","title":"frontThreshold","role":"symbol","type":"topic","url":"\/documentation\/yeofr\/posetarget\/frontthreshold","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"frontThreshold","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"abstract":[{"text":"±7° in radians — ","type":"text"},{"type":"codeVoice","code":"front"},{"text":" requires both axes inside this.","type":"text"}]},"doc://com.youreyeonly.yeofr.YEOFR/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/s8SendableP","title":"Swift.Sendable"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/PoseTarget/pitchThreshold":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/PoseTarget\/pitchThreshold","kind":"symbol","title":"pitc