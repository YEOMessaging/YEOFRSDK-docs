},{"text":" ","type":"text"},{"text":"count as latch evidence. ~200 separates motion-blurred walking","type":"text"},{"text":" ","type":"text"},{"text":"frames from sharp ones on the same trace (112×112 crop scale).","type":"text"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceSharpness","type":"topic","defaultImplementations":1,"role":"symbol","title":"evidenceMinFaceSharpness"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceLuma":{"title":"evidenceMinFaceLuma","kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceLuma","role":"symbol","required":true,"defaultImplementations":1,"type":"topic","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfaceluma","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceLuma","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"}],"abstract":[{"type":"text","text":"Minimum face-crop BT.709 mean luminance (0–255) for a frame to"},{"type":"text","text":" "},{"type":"text","text":"count as latch evidence. Fitted on the 2026-06-05 walking trace:"},{"type":"text","text":" "},{"type":"text","text":"every deep genuine dip sat below ~85 while hits centred ~118."}]},"doc://com.youreyeonly.yeofr.YEOFR/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/s16SendableMetatypeP"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled","title":"latchEvidenceGateEnabled","role":"symbol","required":true,"defaultImplementations":1,"type":"topic","url":"\/documentat