text","text":"hand to the trust pipeline to enable or disable individual signals."}],"kind":"symbol","navigatorTitle":[{"text":"LivenessFusionConfig","kind":"identifier"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfig","role":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceAbstentionCapFrames":{"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceabstentioncapframes","title":"evidenceAbstentionCapFrames","required":true,"abstract":[{"text":"Hard cap on consecutive abstentions (~1.5 s at 20 fps). Past it,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"failing frames count as misses again — the security backstop that"},{"type":"text","text":" "},{"type":"text","text":"keeps an endless dark stream from holding trust forever."}],"role":"symbol","defaultImplementations":1,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceAbstentionCapFrames","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceAbstentionCapFrames","type":"topic","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable":{"kind":"symbol","abstract":[{"type":"text","text":"The toggles the FR-trust pipeline reads to decide which signals — the"},{"type":"text","text":" "},{"type":"text","text":"liveness CNN and TrueDepth — contribute to a frame’s trust verdict."}],"type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LivenessFusionConfigurable","kind":"identifier"}],"navigatorTitle":[{"text":"LivenessFusionConfigurable","kind":"identifier"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","title":"LivenessFusionConfigurable","url":"\/documentation\/yeofr\/livenessfusionconfigurable"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/depthTrustFlatDropFrames":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Consecutive raw-flat frames required to drop the trust gate’s"},{"type":"text","text":" "},{"type":"text","text":"confirmed-3D signal ("},{"type":"codeVoice","code":"depthTrustConfirmedThreeD"},{"type":"text","text":"). Asymmetric"},{"type":"text","text":" "},{"type":"text","text":"revoke-side stickiness for the depth signal "},{"type":"emphasis","inlineContent":[{"text":"only","type":"text"}]},{"type":"text","text":": the 3D-confirm"},{"type":"text","text":" "},{"type":"text","text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so"},{"type":"text","text":" "},{"type":"text","text":"admission timing and the single-blip flash guard are unchanged —"},{"type":"text","text":" "},{"text":"raising this only makes an already-confirmed 3D face ride out","type":"text"},{"text":" ","type":"text"},{"text":"longer transient flat readings under changing light, instead of","type":"text"},{"text":" ","type":"text"},{"text":"collapsing trust on a sensor blip (the depth signal AND-gates the","type":"text"},{"text":" ","type":"text"},{"text":"whole fused verdict, so one flat blip drops trust even while the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"CNN and the recognition latch hold). The evaluator clamps this to"},{"type":"text","text":" "},{"type":"codeVoice","code":"[5, 15]"},{"type":"text","text":" — never below today’s 5, capped so a flat run still"},{"type":"text","text":" "},{"type":"text","text":"surfaces a real spoof \/ face-gone within a fraction of a second."},{"type":"text","text":" "},{"type":"text","text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈"},{"type":"text","text":" "},{"type":"text","text":"400 ms at 20 fps) to smooth lighting-driven trust flicker."}],"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"depthTrustFlatDropFrames"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"required":true,"defaultImplementations":1,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes","title":"depthTrustFlatDropFrames"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceSharpness":{"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfacesharpness","title":"evidenceMinFaceSharpness","required":true,"abstract":[{"type":"text","text":"Minimum face-crop Laplacian variance (sharpness) for a frame to"},{"type":"text","text":" "},{"type":"text","text":"count as latch evidence. ~200 separates motion-blurred walking"},{"type":"text","text":" "},{"type":"text","text":"frames from sharp ones on the same trace (112×112 crop scale)."}],"role":"symbol","defaultImplementations":1,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceSharpness","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceSharpness","type":"topic","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"type":"topic","abstract":[{"text":"Opt-in continuity lever (default ","type":"text"},{"type":"codeVoice","code":"false"},{"text":"): while the recognition","type":"text"},{"text":" ","type":"text"},{"text":"latch is HELD, a frame whose face crop fails the evidence-quality","type":"text"},{"text":" ","type":"text"},{"text":"check (dark \/ blurred — see ","type":"text"},{"type":"codeVoice","code":"FaceEvidenceQuality"},{"text":") and carries no","type":"text"},{"text":" ","type":"text"},{"text":"vendor-named identity casts no vote in the latch windows, so","type":"text"},{"text":" ","type":"text"},{"text":"transient junk frames (AE hunting toward a backlit window, motion","type":"text"},{"text":" ","type":"text"},{"text":"blur while walking) can’t fast-drop a genuine latch. NOT a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"floor change: enter gates are untouched (the gate is inert while"},{"type":"text","text":" "},{"type":"text","text":"unlatched), vendor-named frames always count, and after"},{"type":"text","text":" "},{"type":"codeVoice","code":"evidenceAbstentionCapFrames"},{"type":"text","text":" consecutive abstentions the frames"},{"type":"text","text":" "},{"type":"text","text":"count again — a covered or replaced face still drops trust."}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"latchEvidenceGateEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"required":true,"defaultImplementations":1,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled","title":"latchEvidenceGateEnabled","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/latchevidencegateenabled"},"doc://com.youreyeonly.yeofr.YEOFR/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/s8SendableP"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"type":"topic","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"title":"YEOFR","url":"\/documentation\/yeofr","role":"collection","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useTrueDepthSDK":{"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/usetruedepthsdk","title":"useTrueDepthSDK","required":true,"abstract":[],"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useTrueDepthSDK"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useTrueDepthSDK","type":"topic","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceLuma":{"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfaceluma","title":"evidenceMinFaceLuma","required":true,"abstract":[{"text":"Minimum face-crop BT.709 mean luminance (0–255) for a frame to","type":"text"},{"text":" ","type":"text"},{"text":"count as latch evidence. Fitted on the 2026-06-05 walking trace:","type":"text"},{"text":" ","type":"text"},{"text":"every deep genuine dip sat below ~85 while hits centred ~118.","type":"text"}],"role":"symbol","defaultImplementations":1,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceLuma","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceLuma","kind":"symbol","type":"topic"}}}