ou can build and"},{"type":"text","text":" "},{"type":"text","text":"hand to the trust pipeline to enable or disable individual signals."}],"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfig","role":"symbol","url":"\/documentation\/yeofr\/livenessfusionconfig","kind":"symbol","title":"LivenessFusionConfig","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LivenessFusionConfig"}],"navigatorTitle":[{"kind":"identifier","text":"LivenessFusionConfig"}]},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useTrueDepthSDK":{"title":"useTrueDepthSDK","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useTrueDepthSDK"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/usetruedepthsdk","required":true,"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useTrueDepthSDK"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceSharpness":{"role":"symbol","title":"evidenceMinFaceSharpness","defaultImplementations":1,"abstract":[{"text":"Minimum face-crop Laplacian variance (sharpness) for a frame to","type":"text"},{"text":" ","type":"text"},{"text":"count as latch evidence. ~200 separates motion-blurred walking","type":"text"},{"text":" ","type":"text"},{"text":"frames from sharp ones on the same trace (112×112 crop scale).","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceSharpness","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Float","preciseIdentifier":"s:Sf"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfacesharpness","required":true,"type":"topic","kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceSharpness"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useLivenessSDK":{"title":"useLivenessSDK","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useLivenessSDK"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/uselivenesssdk","required":true,"abstract":[],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useLivenessSDK"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/depthTrustFlatDropFrames":{"title":"depthTrustFlatDropFrames","type":"topic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"depthTrustFlatDropFrames"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes","required":true,"defaultImplementations":1,"abstract":[{"type":"text","text":"Consecutive raw-flat frames required to drop the trust gate’s"},{"type":"text","text":" "},{"type":"text","text":"confirmed-3D signal ("},{"code":"depthTrustConfirmedThreeD","type":"codeVoice"},{"type":"text","text":"). Asymmetric"},{"type":"text","text":" "},{"type":"text","text":"revoke-side stickiness for the depth signal "},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"type":"text","text":": the 3D-confirm"},{"type":"text","text":" "},{"type":"text","text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so"},{"type":"text","text":" "},{"type":"text","text":"admission timing and the single-blip flash guard are unchanged —"},{"type":"text","text":" "},{"type":"text","text":"raising this only makes an already-confirmed 3D face ride out"},{"type":"text","text":" "},{"type":"text","text":"longer transient flat readings under changing light, instead of"},{"type":"text","text":" "},{"type":"text","text":"collapsing trust on a sensor blip (the depth signal AND-gates the"},{"type":"text","text":" "},{"type":"text","text":"whole fused verdict, so one flat blip drops trust even while the"},{"text":" ","type":"text"},{"text":"CNN and the recognition latch hold). The evaluator clamps this to","type":"text"},{"text":" ","type":"text"},{"code":"[5, 15]","type":"codeVoice"},{"type":"text","text":" — never below today’s 5, capped so a flat run still"},{"text":" ","type":"text"},{"text":"surfaces a real spoof \/ face-gone within a fraction of a second.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈"},{"type":"text","text":" "},{"type":"text","text":"400 ms at 20 fps) to smooth lighting-driven trust flicker."}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"title":"latchEvidenceGateEnabled","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"latchEvidenceGateEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/latchevidencegateenabled","required":true,"defaultImplementations":1,"abstract":[{"text":"Opt-in continuity lever (default ","type":"text"},{"code":"false","type":"codeVoice"},{"text":"): while the recognition","type":"text"},{"text":" ","type":"text"},{"text":"latch is HELD, a frame whose face crop fails the evidence-quality","type":"text"},{"text":" ","type":"text"},{"text":"check (dark \/ blurred — see ","type":"text"},{"code":"FaceEvidenceQuality","type":"codeVoice"},{"text":") and carries no","type":"text"},{"text":" ","type":"text"},{"text":"vendor-named identity casts no vote in the latch windows, so","type":"text"},{"text":" ","type":"text"},{"text":"transient junk frames (AE hunting toward a backlit window, motion","type":"text"},{"text":" ","type":"text"},{"text":"blur while walking) can’t fast-drop a genuine latch. NOT a","type":"text"},{"text":" ","type":"text"},{"text":"floor change: enter gates are untouched (the gate is inert while","type":"text"},{"text":" ","type":"text"},{"text":"unlatched), vendor-named frames always count, and after","type":"text"},{"text":" ","type":"text"},{"code":"evidenceAbstentionCapFrames","type":"codeVoice"},{"text":" consecutive abstentions the frames","type":"text"},{"text":" ","type":"text"},{"text":"count again — a covered or replaced face still drops trust.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceAbstentionCapFrames":{"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceAbstentionCapFrames","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceabstentioncapframes","kind":"symbol","required":true,"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"evidenceAbstentionCapFrames"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"defaultImplementations":1,"type":"topic","abstract":[{"type":"text","text":"Hard cap on consecutive abstentions (~1.5 s at 20 fps). Past it,"},{"type":"text","text":" "},{"type":"text","text":"failing frames count as misses again — the security backstop that"},{"type":"text","text":" "},{"type":"text","text":"keeps an endless dark stream from holding trust forever."}],"title":"evidenceAbstentionCapFrames","role":"symbol"},"doc://com.yeomessaging.YEOFR/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/com.yeomessaging.YEOFR\/s16SendableMetatypeP"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionDefaults":{"title":"LivenessFusionDefaults","type":"topic","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LivenessFusionDefaults","kind":"identifier"}],"url":"\/documentation\/yeofr\/livenessfusiondefaults","navigatorTitle":[{"text":"LivenessFusionDefaults","kind":"identifier"}],"abstract":[{"type":"text","text":"The shipped default values for every "},{"type":"reference","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","isActive":true},{"type":"text","text":" "},{"type":"text","text":"toggle, used when a consumer does not override them."}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionDefaults"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable":{"title":"LivenessFusionConfigurable","type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LivenessFusionConfigurable","kind":"identifier"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable","navigatorTitle":[{"text":"LivenessFusionConfigurable","kind":"identifier"}],"abstract":[{"text":"The toggles the FR-trust pipeline reads to decide which signals — the","type":"text"},{"text":" ","type":"text"},{"text":"liveness CNN and TrueDepth — contribute to a frame’s trust verdict.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceLuma":{"title":"evidenceMinFaceLuma","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"evidenceMinFaceLuma"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","kind":"typeIdentifier","text":"Float"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfaceluma","required":true,"defaultImplementations":1,"abstract":[{"text":"Minimum face-crop BT.709 mean luminance (0–255) for a frame to","type":"text"},{"text":" ","type":"text"},{"text":"count as latch evidence. Fitted on the 2026-06-05 walking trace:","type":"text"},{"text":" ","type":"text"},{"text":"every deep genuine dip sat below ~85 while hits centred ~118.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceLuma"},"doc://com.yeomessaging.YEOFR/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/com.yeomessaging.YEOFR\/s8SendableP"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR":{"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","url":"\/documentation\/yeofr","kind":"symbol","type":"topic","abstract":[{"text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing.","type":"text"}],"title":"YEOFR","role":"collection"}}}