","type":"text"},{"code":"depthTrustConfirmedThreeD","type":"codeVoice"},{"text":"). Asymmetric","type":"text"},{"text":" ","type":"text"},{"text":"revoke-side stickiness for the depth signal ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"type":"text","text":": the 3D-confirm"},{"type":"text","text":" "},{"type":"text","text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so"},{"type":"text","text":" "},{"type":"text","text":"admission timing and the single-blip flash guard are unchanged —"},{"type":"text","text":" "},{"type":"text","text":"raising this only makes an already-confirmed 3D face ride out"},{"type":"text","text":" "},{"type":"text","text":"longer transient flat readings under changing light, instead of"},{"type":"text","text":" "},{"type":"text","text":"collapsing trust on a sensor blip (the depth signal AND-gates the"},{"type":"text","text":" "},{"type":"text","text":"whole fused verdict, so one flat blip drops trust even while the"},{"type":"text","text":" "},{"type":"text","text":"CNN and the recognition latch hold). The evaluator clamps this to"},{"type":"text","text":" "},{"code":"[5, 15]","type":"codeVoice"},{"type":"text","text":" — never below today’s 5, capped so a flat run still"},{"type":"text","text":" "},{"type":"text","text":"surfaces a real spoof \/ face-gone within a fraction of a second."},{"type":"text","text":" "},{"type":"text","text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈"},{"type":"text","text":" "},{"type":"text","text":"400 ms at 20 fps) to smooth lighting-driven trust flicker."}],"type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"depthTrustFlatDropFrames"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"kind":"symbol","title":"depthTrustFlatDropFrames","defaultImplementations":1,"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"type":"topic","required":true,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"latchEvidenceGateEnabled","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled","abstract":[{"text":"Opt-in continuity lever (default ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":"): while the recognition"},{"type":"text","text":" "},{"type":"text","text":"latch is HELD, a frame whose face crop fails the evidence-quality"},{"type":"text","text":" "},{"text":"check (dark \/ blurred — see ","type":"text"},{"code":"FaceEvidenceQuality","type":"codeVoice"},{"text":") and carries no","type":"text"},{"text":" ","type":"text"},{"text":"vendor-named identity casts no vote in the latch windows, so","type":"text"},{"text":" ","type":"text"},{"text":"transient junk frames (AE hunting toward a backlit window, motion","type":"text"},{"text":" ","type":"text"},{"text":"blur while walking) can’t fast-drop a genuine latch. NOT a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"floor change: enter gates are untouched (the gate is inert while"},{"text":" ","type":"text"},{"type":"text","text":"unlatched), vendor-named frames always count, and after"},{"type":"text","text":" "},{"code":"evidenceAbstentionCapFrames","type":"codeVoice"},{"type":"text","text":" consecutive abstentions the frames"},{"type":"text","text":" "},{"type":"text","text":"count again — a covered or replaced face still drops trust."}],"role":"symbol","defaultImplementations":1,"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/latchevidencegateenabled","title":"latchEvidenceGateEnabled"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR":{"title":"YEOFR","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR","kind":"symbol","role":"collection","abstract":[{"text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing.","type":"text"}],"type":"topic","url":"\/documentation\/yeofr"},"doc://com.yeomessaging.YEOFR/s16SendableMetatypeP":{"type":"unresolvable","title":"Swift.SendableMetatype","identifier":"doc:\/\/com.yeomessaging.YEOFR\/s16SendableMetatypeP"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfig":{"title":"LivenessFusionConfig","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfig","kind":"symbol","role":"symbol","abstract":[{"text":"A concrete, value-type ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable"},{"text":" you can build and","type":"text"},{"text":" ","type":"text"},{"text":"hand to the trust pipeline to enable or disable individual signals.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LivenessFusionConfig"}],"type":"topic","navigatorTitle":[{"text":"LivenessFusionConfig","kind":"identifier"}],"url":"\/documentation\/yeofr\/livenessfusionconfig"},"doc://com.yeomessaging.YEOFR/s8SendableP":{"type":"unresolvable","title":"Swift.Sendable","identifier":"doc:\/\/com.yeomessaging.YEOFR\/s8SendableP"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceLuma":{"type":"topic","required":true,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceLuma","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Float","preciseIdentifier":"s:Sf"}],"kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceLuma","abstract":[{"text":"Minimum face-crop BT.709 mean luminance (0–255) for a frame to","type":"text"},{"text":" ","type":"text"},{"text":"count as latch evidence. Fitted on the 2026-06-05 walking trace:","type":"text"},{"text":" ","type":"text"},{"text":"every deep genuine dip sat below ~85 while hits centred ~118.","type":"text"}],"role":"symbol","defaultImplementations":1,"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfaceluma","title":"evidenceMinFaceLuma"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useTrueDepthSDK":{"abstract":[],"type":"topic","required":true,"title":"useTrueDepthSDK","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useTrueDepthSDK"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/usetruedepthsdk","kind":"symbol","identifier":"doc:\/\/com.yeomessaging.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useTrueDepthSDK","role":"symbol"},"doc://com.yeomessaging.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceSharpness":{"role":"symbol","required":true,"abstract":[{"text":"Minimum face-crop Laplacian variance (sharpness) for a frame to","type":"text"},{"text":" ","type":"text"},{"text":"count as latch evidence. ~200 separates motion-blurred walking","type":"text"},{"text":" ","type":"text"},{"text":"frames from sharp ones on the same trace (112×112 crop scale).","type":"text"}],"type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceSharpness","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"}],"kind":"symbol","title":"evidenceMinFaceSharpness","defaultImplementations":1,"identifier":"doc:\/\/com.yeomessaging.YEOF