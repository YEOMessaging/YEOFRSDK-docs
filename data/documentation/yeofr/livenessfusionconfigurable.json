rue,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceAbstentionCapFrames","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"defaultImplementations":1,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceAbstentionCapFrames","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Hard cap on consecutive abstentions (~1.5 s at 20 fps). Past it,"},{"text":" ","type":"text"},{"text":"failing frames count as misses again — the security backstop that","type":"text"},{"text":" ","type":"text"},{"text":"keeps an endless dark stream from holding trust forever.","type":"text"}],"type":"topic","title":"evidenceAbstentionCapFrames"},"doc://com.youreyeonly.yeofr.YEOFR/s8SendableP":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/s8SendableP","type":"unresolvable","title":"Swift.Sendable"},"doc://com.youreyeonly.yeofr.YEOFR/s16SendableMetatypeP":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/s16SendableMetatypeP","type":"unresolvable","title":"Swift.SendableMetatype"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"abstract":[{"text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing.","type":"text"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","type":"topic","title":"YEOFR","role":"collection","url":"\/documentation\/yeofr","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfig":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfig","role":"symbol","url":"\/documentation\/yeofr\/livenessfusionconfig","navigatorTitle":[{"kind":"identifier","text":"LivenessFusionConfig"}],"type":"topic","title":"LivenessFusionConfig","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LivenessFusionConfig"}],"abstract":[{"text":"A concrete, value-type ","type":"text"},{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","isActive":true,"type":"reference"},{"text":" you can build and","type":"text"},{"text":" ","type":"text"},{"text":"hand to the trust pipeline to enable or disable individual signals.","type":"text"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useTrueDepthSDK":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"useTrueDepthSDK","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useTrueDepthSDK","type":"topic","required":true,"title":"useTrueDepthSDK","role":"symbol","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/usetruedepthsdk","kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/depthTrustFlatDropFrames":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"depthTrustFlatDropFrames","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"defaultImplementations":1,"kind":"symbol","role":"symbol","title":"depthTrustFlatDropFrames","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes","type":"topic","abstract":[{"type":"text","text":"Consecutive raw-flat frames required to drop the trust gate’s"},{"type":"text","text":" "},{"type":"text","text":"confirmed-3D signal ("},{"type":"codeVoice","code":"depthTrustConfirmedThreeD"},{"type":"text","text":"). Asymmetric"},{"type":"text","text":" "},{"type":"text","text":"revoke-side stickiness for the depth signal "},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"type":"text","text":": the 3D-confirm"},{"type":"text","text":" "},{"type":"text","text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so"},{"type":"text","text":" "},{"type":"text","text":"admission timing and the single-blip flash guard are unchanged —"},{"type":"text","text":" "},{"type":"text","text":"raising this only makes an already-confirmed 3D face ride out"},{"type":"text","text":" "},{"type":"text","text":"longer transient flat readings under changing light, instead of"},{"type":"text","text":" "},{"type":"text","text":"collapsing trust on a sensor blip (the depth signal AND-gates the"},{"type":"text","text":" "},{"type":"text","text":"whole fused verdict, so one flat blip drops trust even while the"},{"type":"text","text":" "},{"type":"text","text":"CNN and the recognition latch hold). The evaluator clamps this to"},{"type":"text","text":" "},{"code":"[5, 15]","type":"codeVoice"},{"type":"text","text":" — never below today’s 5, capped so a flat run still"},{"type":"text","text":" "},{"type":"text","text":"surfaces a real spoof \/ face-gone within a fraction of a second."},{"type":"text","text":" "},{"type":"text","text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈"},{"text":" ","type":"text"},{"type":"text","text":"400 ms at 20 fps) to smooth lighting-driven trust flicker."}],"required":true},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"title":"latchEvidenceGateEnabled","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"latchEvidenceGateEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"type":"topic","defaultImplementations":1,"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/latchevidencegateenabled","abstract":[{"type":"text","text":"Opt-in continuity lever (default "},{"type":"codeVoice","code":"false"},{"type":"text","text":"): while the recognition"},{"type":"text","text":" "},{"type":"text","text":"latch is HELD, a frame whose face crop fails the evidence-quality"},{"type":"text","text":" "},{"type":"text","text":"check (dark \/ blurred — see "},{"type":"codeVoice","code":"FaceEvidenceQuality"},{"type":"text","text":") and carries no"},{"type":"text","text":" "},{"type":"text","text":"vendor-named identity casts no vote in the latch windows, so"},{"type":"text","text":" "},{"type":"text","text":"transient junk frames (AE hunting toward a backlit window, motion"},{"type":"text","text":" "},{"type":"text","text":"blur while walking) can’t fast-drop a genuine latch. NOT a"},{"type":"text","text":" "},{"type":"text","text":"floor change: enter gates are untouched (the gate is inert while"},{"type":"text","text":" "},{"type":"text","text":"unlatched), vendor-named frames always count, and after"},{"type":"text","text":" "},{"type":"codeVoice","code":"evidenceAbstentionCapFrames"},{"type":"text","text":" consecutive abstentions the frames"},{"type":"text","text":" "},{"type":"text","text":"count again — a covered or replaced face still drops trust."}],"required":true,"role":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useLivenessSDK":{"title":"useLivenessSDK","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useLivenessSDK"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useLivenessSDK","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/uselivenesssdk","abstract":[],"required":true,"role":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable":{"title":"LivenessFusionConfigurable","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LivenessFusionConfigurable","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"LivenessFusionConfigurable","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","abstract":[{"type":"text","text":"The toggles the FR-trust pipeline reads to decide which signals — the"},{"type":"text","text":" "},{"type":"text","text":"liveness CNN and TrueDepth — contribute to a frame’s trust verdict."}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable","role":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceLuma":{"title":"evidenceMinFaceLuma","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceLuma","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"}],"type":"topic","defaultImplementations":1,"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceLuma","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfaceluma","abstract":[{"text":"Minimum face-crop BT.709 mean luminance (0–255) for a frame to","type":"text"},{"text":" ","type":"text"},{"text":"count as latch evidence. Fitted on the 2026-06-05 walking trace:","type":"text"},{"text":" ","type":"text"},{"text":"every deep genuine dip sat below ~85 while hits centred ~118.","type":"text"}],"required":true,"role":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceMinFaceSharpness":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceSharpness","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceSharpness","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"}],"defaultImplementations":1,"kind":"symbol","role":"symbol","title":"evidenceMinFaceSharpness","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfacesharpness","type":"topic","abstract":[{"type":"text","text":"Minimum face-crop Laplacian variance (sharpness) for a frame to"},{"type":"text","text":" "},{"type":"text","text":"count as latch evidence. ~200 separates motion-blurred walking"},{"type":"text","text":" "},{"type":"text","text":"frames from sharp ones on the same trace (112×112 crop scale)."}],"required":true},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionDefaults":{"title":"LivenessFusionDefaults","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LivenessFusionDefaults","kind":"identifier"}],"type":"topic","navigatorTitle":[{"text":"LivenessFusionDefaults","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionDefaults","url":"\/documentation\/yeofr\/livenessfusiondefaults","abstract":[{"type":"text","text":"The shipped default values for every "},{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"toggle, used when a consumer does not override them.","type":"text"}],"role":"symbol"}}}