:"text"},{"text":"LivenessFusionDefaults","kind":"identifier"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionDefaults","title":"LivenessFusionDefaults","navigatorTitle":[{"text":"LivenessFusionDefaults","kind":"identifier"}],"abstract":[{"text":"The shipped default values for every ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable"},{"text":" ","type":"text"},{"text":"toggle, used when a consumer does not override them.","type":"text"}],"role":"symbol","url":"\/documentation\/yeofr\/livenessfusiondefaults","kind":"symbol","type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/depthTrustFlatDropFrames":{"type":"topic","defaultImplementations":1,"abstract":[{"type":"text","text":"Consecutive raw-flat frames required to drop the trust gate’s"},{"type":"text","text":" "},{"type":"text","text":"confirmed-3D signal ("},{"type":"codeVoice","code":"depthTrustConfirmedThreeD"},{"type":"text","text":"). Asymmetric"},{"type":"text","text":" "},{"type":"text","text":"revoke-side stickiness for the depth signal "},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"type":"text","text":": the 3D-confirm"},{"type":"text","text":" "},{"type":"text","text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so"},{"type":"text","text":" "},{"type":"text","text":"admission timing and the single-blip flash guard are unchanged —"},{"type":"text","text":" "},{"type":"text","text":"raising this only makes an already-confirmed 3D face ride out"},{"type":"text","text":" "},{"type":"text","text":"longer transient flat readings under changing light, instead of"},{"type":"text","text":" "},{"type":"text","text":"collapsing trust on a sensor blip (the depth signal AND-gates the"},{"type":"text","text":" "},{"type":"text","text":"whole fused verdict, so one flat blip drops trust even while the"},{"type":"text","text":" "},{"type":"text","text":"CNN and the recognition latch hold). The evaluator clamps this to"},{"type":"text","text":" "},{"type":"codeVoice","code":"[5, 15]"},{"type":"text","text":" — never below today’s 5, capped so a flat run still"},{"type":"text","text":" "},{"type":"text","text":"surfaces a real spoof \/ face-gone within a fraction of a second."},{"type":"text","text":" "},{"type":"text","text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈"},{"type":"text","text":" "},{"type":"text","text":"400 ms at 20 fps) to smooth lighting-driven trust flicker."}],"required":true,"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"depthTrustFlatDropFrames","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"kind":"symbol","role":"symbol","title":"depthTrustFlatDropFrames","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfig":{"role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"LivenessFusionConfig"}],"title":"LivenessFusionConfig","url":"\/documentation\/yeofr\/livenessfusionconfig","abstract":[{"type":"text","text":"A concrete, value-type "},{"type":"reference","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","isActive":true},{"type":"text","text":" you can build and"},{"type":"text","text":" "},{"type":"text","text":"hand to the trust pipeline to enable or disable individual signals."}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfig","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"LivenessFusionConfig"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"required":true,"defaultImplementations":1,"role":"symbol","abstract":[{"type":"text","text":"Opt-in continuity lever (default "},{"type":"codeVoice","code":"false"},{"type":"text","text":"): while the recognition"},{"type":"text","text":" "},{"type":"text","text":"latch is HELD, a frame whose face crop fails the evidence-quality"},{"type":"text","text":" "},{"type":"text","text":"check (dark \/ blurred — see "},{"type":"codeVoice","code":"FaceEvidenceQuality"},{"type":"text","text":") and carries no"},{"type":"text","text":" "},{"type":"text","text":"vendor-named identity casts no vote in the latch windows, so"},{"type":"text","text":" "},{"type":"text","text":"transient junk frames (AE hunting toward a backlit window, motion"},{"type":"text","text":" "},{"type":"text","text":"blur while walking) can’t fast-drop a genuine latch. NOT a"},{"type":"text","text":" "},{"type":"text","text":"floor change: enter gates are untouched (the gate is inert while"},{"type":"text","text":" "},{"type":"text","text":"unlatched), vendor-named frames always count, and after"},{"type":"text","text":" "},{"type":"codeVoice","code":"evidenceAbstentionCapFrames"},{"type":"text","text":" consecutive abstentions the frames"},{"type":"text","text":" "},{"type":"text","text":"count again — a covered or replaced face still drops trust."}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/latchevidencegateenabled","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"latchEvidenceGateEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"title":"latchEvidenceGateEnabled"},"doc://com.youreyeonly.yeofr.YEOFR/documentati