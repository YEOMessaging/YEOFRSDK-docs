eIdentifier","text":"Float"}],"required":true,"type":"topic","role":"symbol","title":"evidenceMinFaceLuma","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceLuma","kind":"symbol","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfaceluma","defaultImplementations":1},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable":{"abstract":[],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"LivenessFusionConfigurable"}],"navigatorTitle":[{"kind":"identifier","text":"LivenessFusionConfigurable"}],"type":"topic","role":"symbol","title":"LivenessFusionConfigurable","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","kind":"symbol","url":"\/documentation\/yeofr\/livenessfusionconfigurable"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/depthTrustFlatDropFrames":{"abstract":[{"text":"Consecutive raw-flat frames required to drop the trust gate’s","type":"text"},{"text":" ","type":"text"},{"text":"confirmed-3D signal (","type":"text"},{"type":"codeVoice","code":"depthTrustConfirmedThreeD"},{"text":"). Asymmetric","type":"text"},{"text":" ","type":"text"},{"text":"revoke-side stickiness for the depth signal ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"only","type":"text"}]},{"text":": the 3D-confirm","type":"text"},{"text":" ","type":"text"},{"text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so","type":"text"},{"text":" ","type":"text"},{"text":"admission timing and the single-blip flash guard are unchanged —","type":"text"},{"text":" ","type":"text"},{"text":"raising this only makes an already-confirmed 3D face ride out","type":"text"},{"text":" ","type":"text"},{"text":"longer transient flat readings under changing light, instead of","type":"text"},{"text":" ","type":"text"},{"text":"collapsing trust on a sensor blip (the depth signal AND-gates the","type":"text"},{"text":" ","type":"text"},{"text":"whole fused verdict, so one flat blip drops trust even while the","type":"text"},{"text":" ","type":"text"},{"text":"CNN and the recognition latch hold). The evaluator clamps this to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"[5, 15]"},{"text":" — never below today’s 5, capped so a flat run still","type":"text"},{"text":" ","type":"text"},{"text":"surfaces a real spoof \/ face-gone within a fraction of a second.","type":"text"},{"text":" ","type":"text"},{"text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈","type":"text"},{"text":" ","type":"text"},{"text":"400 ms at 20 fps) to smooth lighting-driven trust flicker.","type":"text"}],"defaultImplementations":1,"kind":"symbol","title":"depthTrustFlatDropFrames","role":"symbol","required":true,"type":"topic","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"depthTrustFlatDropFrames","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled","kind":"symbol","abstract":[{"text":"Opt-in continuity lever (default ","type":"text"},{"type":"codeVoice","code":"false"},{"text":"): while the recognition","type":"text"},{"text":" ","type":"text"},{"text":"latch is HELD, a frame whose face crop fails the evidence-quality","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"check (dark \/ blurred — see "},{"type":"codeVoice","code":"FaceEvidenceQuality"},{"type":"text","text":") and carries no"},{"text":" ","type":"text"},{"text":"vendor-named identity casts no vote in the latch windows, so","type":"text"},{"text":" ","type":"text"},{"text":"transient junk frames (AE hunting toward a backlit window, motion","type":"text"},{"text":" ","type":"text"},{"text":"blur while walking) can’t fast-drop a genuine latch. NOT a","type":"text"},{"text":" ","type":"text"},{"text":"floor change: enter gates are untouched (the gate is inert while","type":"text"},{"text":" ","type":"text"},{"text":"unlatched), vendor-named frames always count, and after","type":"text"},{"text":" ","type":"text"},{"code":"evidenceAbstentionCapFrames","type":"codeVoice"},{"text":" consecutive abstentions the frames","type":"text"},{"text":" ","type":"text"},{"text":"count again — a covered or replaced face still drops trust.","type":"text"}],"role":"symbol","required":true,"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/latchevidencegateenabled","type":"topic","title":"latchEvidenceGateEnabled","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"latchEvidenceGateEnabled"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"defaultImplementations":1},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceAbstentionCapFrames":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceAbstentionCapFrames","kind":"symbol","abstract":[{"text":"Hard cap on consecutive abstentions (~1.5 s at 20 fps). Past it,","type":"text"},{"text":" ","type":"text"},{"text":"failing frames count as misses again — the security backstop that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"keeps an endless dark stream from holding trust forever."}],"role":"symbol","required":true,"url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceabstent