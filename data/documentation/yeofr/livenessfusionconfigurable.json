faultImplementations":1,"role":"symbol","required":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceSharpness","title":"evidenceMinFaceSharpness","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceMinFaceSharpness","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Float","preciseIdentifier":"s:Sf","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Minimum face-crop Laplacian variance (sharpness) for a frame to"},{"type":"text","text":" "},{"type":"text","text":"count as latch evidence. ~200 separates motion-blurred walking"},{"type":"text","text":" "},{"type":"text","text":"frames from sharp ones on the same trace (112×112 crop scale)."}],"kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/evidenceAbstentionCapFrames":{"type":"topic","abstract":[{"type":"text","text":"Hard cap on consecutive abstentions (~1.5 s at 20 fps). Past it,"},{"type":"text","text":" "},{"type":"text","text":"failing frames count as misses again — the security backstop that"},{"type":"text","text":" "},{"type":"text","text":"keeps an endless dark stream from holding trust forever."}],"required":true,"role":"symbol","kind":"symbol","title":"evidenceAbstentionCapFrames","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"evidenceAbstentionCapFrames","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceAbstentionCapFrames","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceabstentioncapframes","defaultImplementations":1},"doc://com.youreyeonly.yeofr.YEOFR/s8SendableP":{"title":"Swift.Sendable","type":"unresolvable","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/s8SendableP"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useLivenessSDK":{"type":"topic","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/uselivenesssdk","role":"symbol","required":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useLivenessSDK","title":"useLivenessSDK","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useLivenessSDK"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"abstract":[],"kind":"symbol"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/depthTrustFlatDropFrames":{"type":"topic","abstract":[{"type":"text","text":"Consecutive raw-flat frames required to drop the trust gate’s"},{"type":"text","text":" "},{"type":"text","text":"confirmed-3D signal ("},{"type":"codeVoice","code":"depthTrustConfirmedThreeD"},{"type":"text","text":"). Asymmetric"},{"type":"text","text":" "},{"type":"text","text":"revoke-side stickiness for the depth signal "},{"type":"emphasis","inlineContent":[{"type":"text","text":"only"}]},{"type":"text","text":": the 3D-confirm"},{"type":"text","text":" "},{"type":"text","text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so"},{"type":"text","text":" "},{"type":"text","text":"admission timing and the single-blip flash guard are unchanged —"},{"type":"text","text":" "},{"type":"text","text":"raising this only makes an already-confirmed 3D face ride out"},{"type":"text","text":" "},{"type":"text","text":"longer transient flat readings under changing light, instead of"},{"type":"text","text":" "},{"type":"text","text":"collapsing trust on a sensor blip (the depth signal AND-gates the"},{"type":"text","text":" "},{"type":"text","text":"whole fused verdict, so one flat blip drops trust even while the"},{"type":"text","text":" "},{"type":"text","text":"CNN and the recognition latch hold). The evaluator clamps this to"},{"type":"text","text":" "},{"type":"codeVoice","code":"[5, 15]"},{"type":"text","text":" — never below today’s 5, capped so a flat run still"},{"type":"text","text":" "},{"text":"surfaces a real spoof \/ face-gone within a fraction of a second.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈"},{"type":"text","text":" "},{"type":"text","text":"400 ms at 20 fps) to smooth lighting-driven trust flicker."}],"required":true,"role":"symbol","kind":"symbol","title":"depthTrustFlatDropFrames","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"depthTrustFlatDropFrames"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes","defaultImplementations":1},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable":{"role":"symbol","url":"\/documentation\/yeofr\/livenessfusionconfigurable","navigatorTitle":[{"kind":"identifier","text":"LivenessFusionConfigurable"}],"abstract":[{"type":"text","text":"The toggles the FR-trust pipeline reads to decide which signals — the"},{"text":" ","type":"text"},{"type":"text","text":"liveness CNN and TrueDepth — contribute to a frame’s trust verdict."}],"title":"LivenessFusionConfigurable","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"LivenessFusionConfigurable"}],"type":"topic","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfig":{"abstract":[{"type":"text","text":"A concrete, value-type "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable"},{"type":"text","text":" you can build and"},{"type":"text","text":" "},{"type":"text","text":"hand to the trust pipeline to enable or disable individual signals."}],"type":"topic","role":"symbol","kind":"symbol","title":"LivenessFusionConfig","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"LivenessFusionConfig","kind":"identifier"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfig","url":"\/documentation\/yeofr\/livenessfusionconfig","navigatorTitle":[{"kind":"identifier","text":"LivenessFusionConfig"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"type":"topic","abstract":[{"type":"text","text":"Opt-in continuity lever (default "},{"code":"false","type":"codeVoice"},{"type":"text","text":"): while the recognition"},{"type":"text","text":" "},{"type":"text","text":"latch is HELD, a frame whose face crop fails the evidence-quality"},{"type":"text","text":" "},{"type":"text","text":"check (dark \/ blurred — see "},{"code":"FaceEvidenceQuality","type":"codeVoice"},{"type":"text","text":") and carries no"},{"type":"text","text":" "},{"type":"text","text":"vendor-named identity casts no vote in the latch windows, so"},{"type":"text","text":" "},{"type":"text","text":"transient junk frames (AE hunting toward a backlit window, motion"},{"type":"text","text":" "},{"type":"text","text":"blur while walking) can’t fast-drop a genuine latch. NOT a"},{"type":"text","text":" "},{"type":"text","text":"floor change: enter gates are untouched (the gate is inert while"},{"type":"text","text":" "},{"type":"text","text":"unlatched), vendor-named frames always count, and after"},{"type":"text","text":" "},{"code":"evidenceAbstentionCapFrames","type":"codeVoice"},{"type":"text","text":" consecutive abstentions the frames"},{"type":"text","text":" "},{"type":"text","text":