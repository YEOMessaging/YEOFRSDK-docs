xt","text":" "},{"kind":"identifier","text":"evidenceMinFaceSharpness"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"}],"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/evidenceMinFaceSharpness","type":"topic","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/evidenceminfacesharpness","abstract":[{"text":"Minimum face-crop Laplacian variance (sharpness) for a frame to","type":"text"},{"text":" ","type":"text"},{"text":"count as latch evidence. ~200 separates motion-blurred walking","type":"text"},{"text":" ","type":"text"},{"text":"frames from sharp ones on the same trace (112×112 crop scale).","type":"text"}],"defaultImplementations":1},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR","kind":"symbol","title":"YEOFR","url":"\/documentation\/yeofr","abstract":[{"type":"text","text":"On-device face recognition with fused liveness and TrueDepth anti-spoofing."}],"role":"collection","type":"topic"},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useTrueDepthSDK":{"role":"symbol","required":true,"title":"useTrueDepthSDK","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useTrueDepthSDK"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useTrueDepthSDK","type":"topic","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/usetruedepthsdk","abstract":[]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/useLivenessSDK":{"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/useLivenessSDK","abstract":[],"type":"topic","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/uselivenesssdk","title":"useLivenessSDK","required":true,"kind":"symbol","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"useLivenessSDK","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/latchEvidenceGateEnabled":{"role":"symbol","required":true,"title":"latchEvidenceGateEnabled","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"latchEvidenceGateEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/latchEvidenceGateEnabled","type":"topic","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/latchevidencegateenabled","abstract":[{"text":"Opt-in continuity lever (default ","type":"text"},{"type":"codeVoice","code":"false"},{"text":"): while the recognition","type":"text"},{"text":" ","type":"text"},{"text":"latch is HELD, a frame whose face crop fails the evidence-quality","type":"text"},{"text":" ","type":"text"},{"text":"check (dark \/ blurred — see ","type":"text"},{"type":"codeVoice","code":"FaceEvidenceQuality"},{"text":") and carries no","type":"text"},{"text":" ","type":"text"},{"text":"vendor-named identity casts no vote in the latch windows, so","type":"text"},{"text":" ","type":"text"},{"text":"transient junk frames (AE hunting toward a backlit window, motion","type":"text"},{"text":" ","type":"text"},{"text":"blur while walking) can’t fast-drop a genuine latch. NOT a","type":"text"},{"text":" ","type":"text"},{"text":"floor change: enter gates are untouched (the gate is inert while","type":"text"},{"text":" ","type":"text"},{"text":"unlatched), vendor-named frames always count, and after","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"evidenceAbstentionCapFrames"},{"text":" consecutive abstentions the frames","type":"text"},{"text":" ","type":"text"},{"text":"count again — a covered or replaced face still drops trust.","type":"text"}],"defaultImplementations":1},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionConfigurable/depthTrustFlatDropFrames":{"role":"symbol","required":true,"title":"depthTrustFlatDropFrames","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"depthTrustFlatDropFrames"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"kind":"symbol","identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable\/depthTrustFlatDropFrames","type":"topic","url":"\/documentation\/yeofr\/livenessfusionconfigurable\/depthtrustflatdropframes","abstract":[{"text":"Consecutive raw-flat frames required to drop the trust gate’s","type":"text"},{"text":" ","type":"text"},{"text":"confirmed-3D signal (","type":"text"},{"type":"codeVoice","code":"depthTrustConfirmedThreeD"},{"text":"). Asymmetric","type":"text"},{"text":" ","type":"text"},{"text":"revoke-side stickiness for the depth signal ","type":"text"},{"inlineContent":[{"text":"only","type":"text"}],"type":"emphasis"},{"text":": the 3D-confirm","type":"text"},{"text":" ","type":"text"},{"text":"path (5 consecutive 3D, no cold-start bypass) is untouched, so","type":"text"},{"text":" ","type":"text"},{"text":"admission timing and the single-blip flash guard are unchanged —","type":"text"},{"text":" ","type":"text"},{"text":"raising this only makes an already-confirmed 3D face ride out","type":"text"},{"text":" ","type":"text"},{"text":"longer transient flat readings under changing light, instead of","type":"text"},{"text":" ","type":"text"},{"text":"collapsing trust on a sensor blip (the depth signal AND-gates the","type":"text"},{"text":" ","type":"text"},{"text":"whole fused verdict, so one flat blip drops trust even while the","type":"text"},{"text":" ","type":"text"},{"text":"CNN and the recognition latch hold). The evaluator clamps this to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"[5, 15]"},{"text":" — never below today’s 5, capped so a flat run still","type":"text"},{"text":" ","type":"text"},{"text":"surfaces a real spoof \/ face-gone within a fraction of a second.","type":"text"},{"text":" ","type":"text"},{"text":"Default 5 preserves current behaviour exactly; raise it (e.g. 8 ≈","type":"text"},{"text":" ","type":"text"},{"text":"400 ms at 20 fps) to smooth lighting-driven trust flicker.","type":"text"}],"defaultImplementations":1},"doc://com.youreyeonly.yeofr.YEOFR/documentation/YEOFR/LivenessFusionDefaults":{"abstract":[{"text":"The shipped default values for every ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionConfigurable","type":"reference"},{"text":" ","type":"text"},{"text":"toggle, used when a consumer does not override them.","type":"text"}],"identifier":"doc:\/\/com.youreyeonly.yeofr.YEOFR\/documentation\/YEOFR\/LivenessFusionDefaults","title":"LivenessFusionDefaults","kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"LivenessFusionDefaults"}],"url":"\/documentation\/yeofr\/livenessfusiondefaults","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"LivenessFusionDefaults"}],"type":"topic"}}}